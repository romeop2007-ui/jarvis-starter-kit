{%- comment -%}
  Sculpted — Panier tiroir (slide-in cart, façon Loop Earplugs).
  Rendu une fois dans le layout → présent sur toutes les pages.

  Fonctionnement :
  - L'icône panier du header (et tout élément [data-cart-open]) ouvre le tiroir.
  - Les boutons "Add to cart" appellent window.SculptedCart.add(items) : ajout en
    AJAX SANS recharger la page, puis ouverture du tiroir.
  - Quantités (+/−) et suppression via /cart/change.js, re-render via la
    Section Rendering API (sections=sculpted-cart-drawer) → toujours à jour.
  - Les remises automatiques produit (ex : "Buy 2 Get 1 Free", cumulables) sont
    déjà reflétées dans item.final_line_price → l'article offert s'affiche "Free".
  - Barre de progression livraison gratuite éditable dans Personnaliser.
  - Repli sans JavaScript : la page /cart reste accessible.
{%- endcomment -%}

{%- assign savings = cart.original_total_price | minus: cart.total_price -%}
{%- comment -%}
  Seul ce produit déclenche la mécanique cadeau "Buy 2 Get 1 Free" dans le tiroir
  (c'est le seul à porter la remise BXGY côté Shopify). Tous les autres produits
  (protège-tibias, futurs produits) sont affichés sans cadeau, sans offre, sans
  remise. Défaut = ID du produit Sculpted ; éditable dans Personnaliser.
{%- endcomment -%}
{%- assign gift_pid = section.settings.gift_product_id | default: '16329009922393' -%}

<div id="CartDrawer" class="cart-drawer" aria-hidden="true">
  <div class="cart-drawer__overlay" data-cart-close></div>
  <aside class="cart-drawer__panel" role="dialog" aria-modal="true" aria-label="{{ section.settings.heading | escape }}">
    <div class="cart-drawer__top">
      <h2 class="cart-drawer__title">{{ section.settings.heading | escape }}</h2>
      <button type="button" class="cart-drawer__close" data-cart-close aria-label="Close">
        <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </div>

    <div class="cart-drawer__inner">
      <span data-cart-count-source data-count="{{ cart.item_count }}" hidden></span>

      {%- if cart.item_count > 0 -%}
        <div class="cd-items">
          {%- comment -%}
            On REGROUPE par produit (pas par ligne brute Shopify). Pour chaque
            produit : total = somme des unités, offerts = total ÷ 3 (chaque 3e
            offert → 2 payés = 1 offert, 4 payés = 2 offerts), payés = total −
            offerts. Le compteur affiché = unités PAYÉES. La ligne offerte gérée
            par Shopify n'est jamais affichée ni éditable séparément.
            data-control = clé de la 1re ligne (où l'on écrit le nouveau total),
            data-others = clés des autres lignes du produit (remises à 0).
          {%- endcomment -%}
          {%- assign seen = '' -%}
          {%- for item in cart.items -%}
            {%- assign pid = item.product_id | append: '' -%}
            {%- assign is_gift = false -%}
            {%- if pid == gift_pid -%}{%- assign is_gift = true -%}{%- endif -%}

            {%- if is_gift -%}
              {%- comment -%}
                PRODUIT À OFFRE (Sculpted) : on REGROUPE par produit. offerts = total
                ÷ 3 (chaque 3e offert), payés = total − offerts. Le compteur affiché =
                unités PAYÉES. data-control = 1re ligne, data-others = lignes à 0.
              {%- endcomment -%}
              {%- assign marker = '|' | append: pid | append: '|' -%}
              {%- unless seen contains marker -%}
                {%- assign seen = seen | append: marker -%}
                {%- assign tot = 0 -%}
                {%- assign unit = 0 -%}
                {%- assign ctrl_key = '' -%}
                {%- assign others = '' -%}
                {%- assign first_item = item -%}
                {%- assign vsummary = '' -%}
                {%- for it2 in cart.items -%}
                  {%- if it2.product_id == item.product_id -%}
                    {%- assign tot = tot | plus: it2.quantity -%}
                    {%- if ctrl_key == '' -%}
                      {%- assign ctrl_key = it2.key -%}
                      {%- assign unit = it2.original_price -%}
                      {%- assign first_item = it2 -%}
                    {%- else -%}
                      {%- assign others = others | append: it2.key | append: ',' -%}
                    {%- endif -%}
                    {%- if it2.variant.title and it2.variant.title != 'Default Title' -%}
                      {%- assign vsummary = vsummary | append: it2.variant.title | append: ' ×' | append: it2.quantity | append: ' · ' -%}
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- assign free = tot | divided_by: 3 -%}
                {%- assign paid = tot | minus: free -%}
                {%- assign line_total = paid | times: unit -%}
                {%- assign orig_total = tot | times: unit -%}
                <div class="cd-item" data-control="{{ ctrl_key }}" data-others="{{ others | strip }}" data-paid="{{ paid }}" data-gift="true">
                  <a class="cd-item__media{% if first_item.image %} has-img{% endif %}" href="{{ first_item.url }}">
                    {%- if first_item.image -%}<img src="{{ first_item.image | image_url: width: 200 }}" alt="{{ first_item.product.title | escape }}" loading="lazy">{%- endif -%}
                  </a>
                  <div class="cd-item__main">
                    <div class="cd-item__row">
                      <a class="cd-item__name" href="{{ first_item.url }}">{{ first_item.product.title | escape }}</a>
                      <button type="button" class="cd-item__remove" data-action="remove" aria-label="Remove">
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                      </button>
                    </div>
                    {%- if vsummary != '' -%}
                      <p class="cd-item__opt">{{ vsummary | split: ' · ' | join: ' · ' }}</p>
                    {%- endif -%}
                    {%- if free > 0 -%}
                      <p class="cd-item__gift">+{{ free }} {{ section.settings.gift_badge | escape }}</p>
                    {%- endif -%}
                    <div class="cd-item__foot">
                      <div class="cd-qty">
                        <button type="button" data-action="dec" aria-label="Decrease">−</button>
                        <span>{{ paid }}</span>
                        <button type="button" data-action="inc" aria-label="Increase">+</button>
                      </div>
                      <div class="cd-price">
                        <span class="cd-price__now">{{ line_total | money }}</span>
                        {%- if free > 0 -%}
                          <span class="cd-price__was">{{ orig_total | money }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                  </div>
                </div>
              {%- endunless -%}

            {%- else -%}
              {%- assign is_pack = false -%}
              {%- if item.product.options contains 'Pack' -%}{%- assign is_pack = true -%}{%- endif -%}

              {%- if is_pack -%}
                {%- comment -%}
                  PRODUIT PACK (protège-tibias) : le +/− change de VARIANTE pack
                  (1↔2↔3↔4 paires), PAS la quantité. Le libellé ("N Pairs") et le prix
                  réel du pack suivent. Aucun cadeau. On passe au JS le mapping
                  paires→variante et les propriétés couleur/taille à conserver.
                {%- endcomment -%}
                {%- assign pack_map = '' -%}
                {%- assign pack_max = 1 -%}
                {%- for v in item.product.variants -%}
                  {%- assign vn = v.title | split: ' ' | first -%}
                  {%- assign pack_map = pack_map | append: vn | append: ':' | append: v.id | append: ',' -%}
                  {%- assign vni = vn | plus: 0 -%}
                  {%- if vni > pack_max -%}{%- assign pack_max = vni -%}{%- endif -%}
                {%- endfor -%}
                {%- assign cur_pairs = item.variant.title | split: ' ' | first -%}
                <div class="cd-item" data-pack="true" data-line="{{ item.key }}" data-current="{{ cur_pairs }}" data-max="{{ pack_max }}" data-map="{{ pack_map | strip }}" data-props="{{ item.properties | json | escape }}" data-gift="false">
                  <a class="cd-item__media{% if item.image %} has-img{% endif %}" href="{{ item.url }}">
                    {%- if item.image -%}<img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.product.title | escape }}" loading="lazy">{%- endif -%}
                  </a>
                  <div class="cd-item__main">
                    <div class="cd-item__row">
                      <a class="cd-item__name" href="{{ item.url }}">{{ item.product.title | escape }}</a>
                      <button type="button" class="cd-item__remove" data-action="remove" aria-label="Remove">
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                      </button>
                    </div>
                    <p class="cd-item__opt">{{ item.variant.title | escape }}</p>
                    {%- comment -%}
                      Détail de CE que le client a pris : couleur / taille de chaque paire,
                      lu depuis les propriétés de ligne (Pair 1, Pair 2…). On saute les
                      propriétés cachées (préfixe "_") et les valeurs vides.
                    {%- endcomment -%}
                    {%- assign show_pairs = false -%}
                    {%- for property in item.properties -%}
                      {%- assign pfirst = property.first | slice: 0 -%}
                      {%- if property.last != blank and pfirst != '_' -%}{%- assign show_pairs = true -%}{%- endif -%}
                    {%- endfor -%}
                    {%- if show_pairs -%}
                      <ul class="cd-item__pairs">
                        {%- for property in item.properties -%}
                          {%- assign pfirst = property.first | slice: 0 -%}
                          {%- if property.last != blank and pfirst != '_' -%}
                            <li><span>{{ property.first | escape }}:</span> {{ property.last | escape }}</li>
                          {%- endif -%}
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                    <div class="cd-item__foot">
                      <div class="cd-qty">
                        <button type="button" data-action="dec" aria-label="Decrease">−</button>
                        <span>{{ cur_pairs }}</span>
                        <button type="button" data-action="inc" aria-label="Increase">+</button>
                      </div>
                      <div class="cd-price">
                        <span class="cd-price__now">{{ item.final_line_price | money }}</span>
                      </div>
                    </div>
                  </div>
                </div>

              {%- else -%}
                {%- comment -%}
                  PRODUIT SIMPLE sans offre : une carte par ligne, vraie quantité,
                  vrai prix Shopify. inc/dec agit sur la quantité de la ligne.
                {%- endcomment -%}
                <div class="cd-item" data-control="{{ item.key }}" data-others="" data-paid="{{ item.quantity }}" data-gift="false">
                  <a class="cd-item__media{% if item.image %} has-img{% endif %}" href="{{ item.url }}">
                    {%- if item.image -%}<img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.product.title | escape }}" loading="lazy">{%- endif -%}
                  </a>
                  <div class="cd-item__main">
                    <div class="cd-item__row">
                      <a class="cd-item__name" href="{{ item.url }}">{{ item.product.title | escape }}</a>
                      <button type="button" class="cd-item__remove" data-action="remove" aria-label="Remove">
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                      </button>
                    </div>
                    {%- if item.variant.title and item.variant.title != 'Default Title' -%}
                      <p class="cd-item__opt">{{ item.variant.title | escape }}</p>
                    {%- endif -%}
                    <div class="cd-item__foot">
                      <div class="cd-qty">
                        <button type="button" data-action="dec" aria-label="Decrease">−</button>
                        <span>{{ item.quantity }}</span>
                        <button type="button" data-action="inc" aria-label="Increase">+</button>
                      </div>
                      <div class="cd-price">
                        <span class="cd-price__now">{{ item.final_line_price | money }}</span>
                        {%- if item.original_line_price > item.final_line_price -%}
                          <span class="cd-price__was">{{ item.original_line_price | money }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                  </div>
                </div>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="cart-drawer__foot">
          {%- if savings > 0 -%}
            <div class="cd-row cd-row--save"><span>{{ section.settings.savings_label | escape }}</span><b>−{{ savings | money }}</b></div>
          {%- endif -%}
          <div class="cd-row cd-row--total"><span>{{ section.settings.subtotal_label | escape }}</span><b>{{ cart.total_price | money }}</b></div>
          <p class="cd-note">{{ section.settings.shipping_note | escape }}</p>
          <form action="{{ routes.cart_url }}" method="post">
            <button type="submit" name="checkout" class="btn btn-accent btn-block cd-checkout">{{ section.settings.checkout_label | escape }}</button>
          </form>
          <button type="button" class="cd-continue" data-cart-close>{{ section.settings.continue_label | escape }}</button>

          {%- comment -%} Réassurance : piliers centrés et cliquables (pop-up d'explication). {%- endcomment -%}
          {%- if section.settings.show_trust -%}
            <ul class="cd-trust">
              <li>
                <button type="button" class="cd-trust__item" data-trust-open data-title="{{ section.settings.trust_1 | escape }}" data-desc="{{ section.settings.trust_1_desc | escape }}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  <span>{{ section.settings.trust_1 | escape }}</span>
                  <svg class="cd-trust__i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 11.5v4.5" stroke-linecap="round"/><path d="M12 8h.01" stroke-linecap="round"/></svg>
                </button>
              </li>
              <li>
                <button type="button" class="cd-trust__item" data-trust-open data-title="{{ section.settings.trust_2 | escape }}" data-desc="{{ section.settings.trust_2_desc | escape }}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V5z"/><path d="M9 12l2 2 4-4"/></svg>
                  <span>{{ section.settings.trust_2 | escape }}</span>
                  <svg class="cd-trust__i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 11.5v4.5" stroke-linecap="round"/><path d="M12 8h.01" stroke-linecap="round"/></svg>
                </button>
              </li>
              <li>
                <button type="button" class="cd-trust__item" data-trust-open data-title="{{ section.settings.trust_3 | escape }}" data-desc="{{ section.settings.trust_3_desc | escape }}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
                  <span>{{ section.settings.trust_3 | escape }}</span>
                  <svg class="cd-trust__i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 11.5v4.5" stroke-linecap="round"/><path d="M12 8h.01" stroke-linecap="round"/></svg>
                </button>
              </li>
            </ul>
          {%- endif -%}

          {%- if section.settings.show_secure -%}
            <p class="cd-secure">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
              <span>{{ section.settings.secure_text | escape }}</span>
            </p>
          {%- endif -%}

          {%- if section.settings.show_payment -%}
            <div class="cd-pay" aria-label="Accepted payment methods">
              {%- assign pays = section.settings.pay_row | split: ',' -%}
              {%- for p in pays -%}{% render 'sculpted-pay-icon', name: p %}{%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="cd-empty">
          <p>{{ section.settings.empty_text | escape }}</p>
          <button type="button" class="btn btn-accent" data-cart-close>{{ section.settings.empty_btn | escape }}</button>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Pop-up d'explication des piliers de confiance (hors zone re-rendue). {%- endcomment -%}
    <div class="cd-tmodal" id="cd-tmodal" aria-hidden="true" role="dialog" aria-modal="true">
      <div class="cd-tmodal__backdrop" data-tm-close></div>
      <div class="cd-tmodal__box" role="document">
        <button type="button" class="cd-tmodal__x" data-tm-close aria-label="Close">
          <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="cd-tmodal__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 7"/></svg></div>
        <h4 class="cd-tmodal__title" data-tm-title></h4>
        <p class="cd-tmodal__desc" data-tm-desc></p>
      </div>
    </div>
  </aside>
</div>

<style>
/* --- Détail des paires choisies (couleur / taille) sous la ligne "N Pairs" --- */
#CartDrawer .cd-item__pairs{list-style:none;margin:5px 0 0;padding:0;display:flex;flex-direction:column;gap:2px}
#CartDrawer .cd-item__pairs li{font-size:12px;line-height:1.35;color:#6b7280}
#CartDrawer .cd-item__pairs li span{font-weight:600;color:#374151}

/* --- Fix scroll / débordement du tiroir (auto-contenu, override de sculpted.css) --- */
.cart-drawer__inner{-webkit-overflow-scrolling:touch}
.cd-items{flex:0 0 auto}            /* plus de vide géant : le pied suit le contenu */
.cart-drawer__foot{flex:0 0 auto}   /* le pied participe au scroll de l'inner */

/* --- Réassurance du tiroir (piliers centrés et cliquables) --- */
.cd-trust{list-style:none;margin:16px 0 0;padding:14px 0 0;border-top:1px solid rgba(0,0,0,.08);display:flex;flex-direction:column;gap:4px}
.cd-trust li{display:block}
.cd-trust__item{display:flex;align-items:center;justify-content:center;gap:9px;width:100%;background:none;border:none;cursor:pointer;font:inherit;color:#222;font-size:13px;line-height:1.3;padding:7px 8px;border-radius:8px;transition:background .15s}
.cd-trust__item:hover{background:#f4f5f7}
.cd-trust__item > svg:first-child{width:19px;height:19px;flex:0 0 19px;color:#1496d6}
.cd-trust__item span{font-weight:500}
.cd-trust__i{width:15px;height:15px;flex:0 0 15px;color:#9aa3ad}
.cd-secure{display:flex;align-items:center;justify-content:center;gap:7px;margin:12px 0 0;font-size:12px;font-weight:600;letter-spacing:.02em;color:#3a7d44}
.cd-secure svg{width:14px;height:14px;flex:0 0 14px}
.cd-pay{display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:7px;margin:11px 0 0}
.cd-pay .pay-svg{height:24px;width:auto;display:block}

/* --- Pop-up d'explication des piliers --- */
.cd-tmodal{position:absolute;inset:0;z-index:20;display:none;align-items:center;justify-content:center;padding:24px}
.cd-tmodal.is-open{display:flex}
.cd-tmodal__backdrop{position:absolute;inset:0;background:rgba(16,17,20,.5)}
.cd-tmodal__box{position:relative;background:#fff;border-radius:16px;max-width:320px;width:100%;padding:26px 22px 24px;text-align:center;box-shadow:0 24px 60px -20px rgba(16,17,20,.5)}
.cd-tmodal__x{position:absolute;top:10px;right:10px;display:flex;align-items:center;justify-content:center;width:34px;height:34px;border:none;background:none;color:#6b7280;cursor:pointer;border-radius:50%;transition:background .15s}
.cd-tmodal__x:hover{background:#f4f5f7}
.cd-tmodal__icon{width:46px;height:46px;margin:0 auto 12px;border-radius:50%;background:#e6f4fb;color:#1496d6;display:flex;align-items:center;justify-content:center}
.cd-tmodal__icon svg{width:24px;height:24px}
.cd-tmodal__title{font-size:17px;font-weight:800;margin:0 0 8px;color:#101114}
.cd-tmodal__desc{font-size:14px;line-height:1.55;color:#4b5563;margin:0}
</style>

<script>
(function(){
  var drawer = document.getElementById('CartDrawer');
  if(!drawer){ return; }
  var SECTION = 'sculpted-cart-drawer';
  function inner(){ return drawer.querySelector('.cart-drawer__inner'); }
  function open(){ drawer.classList.add('is-open'); drawer.setAttribute('aria-hidden','false'); document.documentElement.classList.add('cd-lock'); }
  function close(){ drawer.classList.remove('is-open'); drawer.setAttribute('aria-hidden','true'); document.documentElement.classList.remove('cd-lock'); }
  function busy(b){ drawer.classList.toggle('is-busy', !!b); }

  /* Pop-up d'explication d'un pilier de confiance. */
  var tmodal = drawer.querySelector('#cd-tmodal');
  function openTrust(btn){
    if(!tmodal){ return; }
    var t = tmodal.querySelector('[data-tm-title]');
    var d = tmodal.querySelector('[data-tm-desc]');
    if(t){ t.textContent = btn.getAttribute('data-title') || ''; }
    if(d){ d.textContent = btn.getAttribute('data-desc') || ''; }
    tmodal.classList.add('is-open');
    tmodal.setAttribute('aria-hidden', 'false');
  }
  function closeTrust(){
    if(!tmodal){ return; }
    tmodal.classList.remove('is-open');
    tmodal.setAttribute('aria-hidden', 'true');
  }

  function setCount(n){
    document.querySelectorAll('[data-cart-count]').forEach(function(el){
      el.textContent = n;
      if(parseInt(n,10) > 0){ el.removeAttribute('hidden'); } else { el.setAttribute('hidden',''); }
    });
  }
  function replaceInner(html){
    try{
      var doc = new DOMParser().parseFromString(html, 'text/html');
      var fresh = doc.querySelector('.cart-drawer__inner');
      if(fresh){ inner().innerHTML = fresh.innerHTML; }
      var src = doc.querySelector('[data-cart-count-source]');
      if(src){ setCount(src.getAttribute('data-count')); }
    }catch(e){}
  }
  function pull(){
    return fetch(window.location.pathname + '?sections=' + SECTION, { headers: { 'Accept': 'application/json' } })
      .then(function(r){ return r.json(); })
      .then(function(d){ if(d && d[SECTION]){ replaceInner(d[SECTION]); } });
  }
  function add(items, btn, orig){
    busy(true);
    return fetch('/cart/add.js', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ items: items, sections: SECTION, sections_url: window.location.pathname }) })
      .then(function(r){ if(!r.ok){ throw new Error('add'); } return r.json(); })
      .then(function(data){ if(data.sections && data.sections[SECTION]){ replaceInner(data.sections[SECTION]); return; } return pull(); })
      .then(function(){ busy(false); if(btn){ btn.disabled=false; if(orig){ btn.textContent=orig; } } open(); })
      .catch(function(){ busy(false); if(btn){ btn.disabled=false; if(orig){ btn.textContent=orig; } } alert('Something went wrong adding to cart. Please try again.'); });
  }
  /* On envoie un objet "updates" keyé par clé de ligne : la ligne de contrôle
     reçoit le nouveau total du produit, les autres lignes passent à 0. Shopify
     recalcule alors lui-même la remise (offerts = total ÷ 3). */
  function update(updates){
    busy(true);
    return fetch('/cart/update.js', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ updates: updates, sections: SECTION, sections_url: window.location.pathname }) })
      .then(function(r){ if(!r.ok){ throw new Error('update'); } return r.json(); })
      .then(function(data){ if(data.sections && data.sections[SECTION]){ replaceInner(data.sections[SECTION]); return; } return pull(); })
      .then(function(){ busy(false); })
      .catch(function(){ busy(false); alert('Could not update the cart. Please try again.'); });
  }

  /* Produit PACK : le +/− change de variante (1↔2↔3↔4 paires) au lieu de la
     quantité. On retire la ligne courante puis on ajoute la variante du pack
     cible (quantité 1), en conservant les propriétés couleur/taille. Le prix et
     le libellé "N Pairs" se mettent à jour tout seuls au re-render. */
  function packStep(itemEl, act){
    var cur = parseInt(itemEl.getAttribute('data-current'), 10) || 1;
    var max = parseInt(itemEl.getAttribute('data-max'), 10) || cur;
    var line = itemEl.getAttribute('data-line');
    var target = cur;
    if(act === 'inc'){ target = Math.min(cur + 1, max); }
    else if(act === 'dec'){ target = cur - 1; }
    else if(act === 'remove'){ target = 0; }
    else { return; }
    if(target === cur && act !== 'remove'){ return; }
    /* Suppression (dernier pack atteint ou croix) : on passe par /cart/update.js,
       le même mécanisme fiable que pour le reste du panier. */
    if(target <= 0){
      var u = {}; u[line] = 0;
      update(u);
      return;
    }
    /* Changement de pack : on retire la ligne courante puis on ajoute la variante
       du pack cible (quantité 1), en conservant les propriétés couleur/taille. */
    var map = {};
    (itemEl.getAttribute('data-map') || '').split(',').filter(Boolean).forEach(function(p){
      var i = p.indexOf(':'); if(i > 0){ map[p.slice(0, i)] = p.slice(i + 1); }
    });
    var props = {};
    try{
      var raw = JSON.parse(itemEl.getAttribute('data-props') || '{}');
      if(raw && typeof raw === 'object'){ Object.keys(raw).forEach(function(k){ if(k.charAt(0) !== '_'){ props[k] = raw[k]; } }); }
    }catch(e){}
    var newVid = map[String(target)];
    if(!newVid){ return; }
    busy(true);
    fetch('/cart/change.js', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ id: line, quantity: 0 }) })
      .then(function(r){ if(!r.ok){ throw new Error('change'); }
        return fetch('/cart/add.js', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ items:[{ id: parseInt(newVid, 10), quantity: 1, properties: props }], sections: SECTION, sections_url: window.location.pathname }) });
      })
      .then(function(r){ if(!r.ok){ throw new Error('add'); } return r.json(); })
      .then(function(data){ if(data.sections && data.sections[SECTION]){ replaceInner(data.sections[SECTION]); return; } return pull(); })
      .then(function(){ busy(false); })
      .catch(function(){ busy(false); pull(); });
  }

  window.SculptedCart = { open: function(){ open(); pull(); }, close: close, add: add, refresh: pull };

  document.addEventListener('click', function(e){
    var opener = e.target.closest('[data-cart-open]');
    if(opener){ e.preventDefault(); open(); pull(); }
  });
  drawer.addEventListener('click', function(e){
    var trustBtn = e.target.closest('[data-trust-open]');
    if(trustBtn){ openTrust(trustBtn); return; }
    if(e.target.closest('[data-tm-close]')){ closeTrust(); return; }
    if(e.target.closest('[data-cart-close]')){ close(); return; }
    var ctrl = e.target.closest('[data-action]');
    if(!ctrl){ return; }
    var itemEl = ctrl.closest('.cd-item');
    if(!itemEl){ return; }
    var act = ctrl.getAttribute('data-action');
    if(itemEl.getAttribute('data-pack') === 'true'){ packStep(itemEl, act); return; }
    var control = itemEl.getAttribute('data-control');
    var others = (itemEl.getAttribute('data-others') || '').split(',').filter(Boolean);
    var paid = parseInt(itemEl.getAttribute('data-paid'), 10) || 0;
    var newPaid = paid;
    if(act === 'inc'){ newPaid = paid + 1; }
    else if(act === 'dec'){ newPaid = paid - 1; }
    else if(act === 'remove'){ newPaid = 0; }
    if(newPaid < 0){ newPaid = 0; }
    /* total à mettre en panier. Produit avec offre (Sculpted) : on ajoute
       floor(newPaid/2) offerts via la remise Shopify "buy 2 get 1" (total ÷ 3).
       Tout autre produit (protège-tibias, etc.) : pas de bonus, total = payé. */
    var isGift = itemEl.getAttribute('data-gift') === 'true';
    var newTotal = isGift ? (newPaid + Math.floor(newPaid / 2)) : newPaid;
    var updates = {};
    if(control){ updates[control] = newTotal; }
    others.forEach(function(k){ updates[k] = 0; });
    update(updates);
  });
  document.addEventListener('keydown', function(e){
    if(e.key !== 'Escape'){ return; }
    if(tmodal && tmodal.classList.contains('is-open')){ closeTrust(); return; }
    if(drawer.classList.contains('is-open')){ close(); }
  });
})();
</script>


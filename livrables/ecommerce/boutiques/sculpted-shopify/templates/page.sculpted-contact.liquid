{% layout 'sculpted' %}
{%- comment -%}
  ===========================================================================
  Sculpted — Template de page Contact (rendu 1:1 de la maquette Claude Design)
  ---------------------------------------------------------------------------
  Reproduction EXACTE de "Sculpted Contact.html" : ticker, header/nav, intro
  "Questions?", formulaire, badges de confiance, footer noir. Le CSS et le
  markup sont identiques à la maquette. Seules différences fonctionnelles :
    - le formulaire utilise le formulaire contact NATIF Shopify
      ({% form 'contact' %}) → les messages arrivent sur l'email de la boutique
    - les liens de nav pointent vers des URL Shopify (à ajuster quand les
      autres pages existeront)

  Déploiement : ce template utilise le layout isolé 'sculpted' (1re ligne),
  donc il ne dépend PAS du header/footer de ton thème.
  ===========================================================================
{%- endcomment -%}

<style>
/* ---------- 1. TOKENS ----------------------- */
:root{
  --ink:#101114;
  --paper:#ffffff;
  --soft:#f4f5f7;
  --muted:#73777e;
  --line:#e6e8eb;
  --accent:#1496d6;
  --accent-deep:#0c79b3;
  --ok:#1f9d57;
  --warn:#d2473c;
  --maxw:1180px;
  --gutter:24px;
  --r:14px;
  --t-h1:clamp(38px, 5.6vw, 76px);
  --t-body:17px;
  --t-eyebrow:13px;
}
/* ---------- 2. RESET / BASE ----------------- */
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'Archivo',system-ui,sans-serif;
  color:var(--ink);background:var(--paper);
  font-size:var(--t-body);line-height:1.55;
  -webkit-font-smoothing:antialiased;
}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer;border:none;background:none}
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 var(--gutter)}
.display{font-weight:900;line-height:1.02;letter-spacing:-.01em}
.accent{color:var(--accent)}
.icon{width:21px;height:21px;stroke:currentColor;fill:none;stroke-width:1.7}
/* ---------- 3. BUTTONS ---------------------- */
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:10px;
  font-weight:700;font-size:14px;letter-spacing:.08em;text-transform:uppercase;
  padding:18px 40px;border-radius:999px;transition:transform .15s ease, background .15s ease;
}
.btn:active{transform:translateY(1px)}
.btn-primary{background:var(--ink);color:#fff}
.btn-primary:hover{background:#000}
/* ---------- 6. CONTACT SECTION -------------- */
.contact{padding:96px 0 110px}
.contact-grid{display:grid;grid-template-columns:1fr 1.15fr;gap:72px;align-items:start}
.contact-intro h1{font-size:var(--t-h1);margin-bottom:28px}
.contact-intro p{color:var(--muted);font-size:18px;max-width:34ch;margin-bottom:30px}
.contact-intro a.mail{font-weight:700;color:var(--ink);text-decoration:underline;text-underline-offset:4px}
.contact-meta{margin-top:40px;display:flex;flex-direction:column;gap:20px}
.contact-meta .row{display:flex;align-items:center;gap:14px}
.contact-meta .row .ic{width:22px;height:22px;stroke:var(--accent);fill:none;stroke-width:1.7;flex:none}
.contact-meta .row b{display:block;font-size:15px}
.contact-meta .row span{font-size:14px;color:var(--muted)}
/* form card */
.form-card{background:var(--soft);border-radius:var(--r);padding:40px}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px}
.field label{display:block;font-size:12px;font-weight:700;letter-spacing:.08em;
  text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.field input,.field textarea{
  width:100%;background:#fff;border:1px solid var(--line);border-radius:10px;
  padding:15px 16px;font-family:inherit;font-size:15px;color:var(--ink);outline:none;
  transition:border-color .15s, box-shadow .15s;
}
.field input:focus,.field textarea:focus{
  border-color:var(--accent);box-shadow:0 0 0 3px rgba(20,150,214,.12);
}
.field textarea{resize:vertical;min-height:150px}
.form-msg{margin-bottom:22px}
.sent-note{display:none;color:var(--ok);font-weight:700;font-size:14px;margin-top:16px}
.sent-note.show{display:block}
.error-note{color:var(--warn);font-weight:700;font-size:14px;margin-bottom:16px}
/* ---------- 7. RESPONSIVE ------------------- */
@media (max-width:980px){
  .nav-links{display:none}
  .contact-grid{grid-template-columns:1fr;gap:44px}
}
@media (max-width:560px){
  .contact{padding:60px 0 70px}
  .form-grid{grid-template-columns:1fr}
  .form-card{padding:26px}
}
</style>

<!-- ============ CONTACT ============ -->
<section class="contact">
  <div class="wrap contact-grid">

    <!-- intro / details -->
    <div class="contact-intro">
      <h1 class="display">Questions?</h1>
      <p>Get in touch below, or email us anytime — we reply within 24 hours.</p>
      <a href="mailto:contact@zooryn.com" class="mail">contact@zooryn.com</a>

      <div class="contact-meta">
        <div class="row">
          <svg class="ic" viewBox="0 0 24 24"><path d="M4 5h16v14H4z"/><path d="M4 6l8 6 8-6"/></svg>
          <div><b>Email</b><span>contact@zooryn.com</span></div>
        </div>
        <div class="row">
          <svg class="ic" viewBox="0 0 24 24"><path d="M4 13a8 8 0 0116 0M4 13v3a2 2 0 002 2M20 13v3a2 2 0 01-2 2h-3"/></svg>
          <div><b>Customer service</b><span>Available 24/7</span></div>
        </div>
        <div class="row">
          <svg class="ic" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
          <div><b>Response time</b><span>Within 24 hours</span></div>
        </div>
      </div>
    </div>

    <!-- form (formulaire contact natif Shopify) -->
    <div class="form-card">
      {%- form 'contact', id: 'contactForm' -%}
        {%- if form.posted_successfully? -%}
          <p class="sent-note show">Thanks — your message is on its way. We'll be in touch within 24 hours.</p>
        {%- elsif form.errors -%}
          <p class="error-note">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <div class="form-grid">
          <div class="field">
            <label for="name">Name</label>
            <input type="text" id="name" name="contact[name]" placeholder="Your name" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" required />
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input type="email" id="email" name="contact[email]" placeholder="you@email.com" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required />
          </div>
        </div>
        <div class="field form-msg">
          <label for="message">Message</label>
          <textarea id="message" name="contact[body]" placeholder="How can we help?" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>
        <button type="submit" class="btn btn-primary">Send message</button>
      {%- endform -%}
    </div>

  </div>
</section>

<!-- ============ TRUST BADGES (interactifs, pop-up — section partagée) ============ -->
{% section 'sculpted-trust-badges' %}

{% comment %}
  Renders cart drawer (skin Zooryn façon BioRoot Labs : header simple, ligne produit avec
  économies affichées, footer Économies/Sous-total/Garantie, cross-sell fonctionnel).
  Tous les ids/attributs requis par cart.js et cart-drawer.js sont conservés à l'identique
  (CartDrawer-Item-X, Drawer-quantity-X, cart-remove-button data-index, etc.) pour ne pas
  casser l'AJAX natif (quantité, suppression, checkout).

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}

{{ 'zooryn-cart.css' | asset_url | stylesheet_tag }}
{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'zooryn-cart-crosssell.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer {
    visibility: hidden;
  }
</style>

<cart-drawer class="drawer zcart{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="drawer__inner zcart__inner gradient color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      {%- if cart == empty -%}
        <div class="drawer__inner-empty">
          <div class="cart-drawer__warnings center{% if settings.cart_drawer_collection != blank %} cart-drawer__warnings--has-collection{% endif %}">
            <div class="cart-drawer__empty-content">
              <h2 class="cart__empty-text">Ton panier est vide</h2>
              <button
                class="drawer__close"
                type="button"
                onclick="this.closest('cart-drawer').close()"
                aria-label="{{ 'accessibility.close' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-close.svg' | inline_asset_content -}}
                </span>
              </button>
              <a href="{{ routes.all_products_collection_url }}" class="button">
                Continuer mes achats
              </a>
            </div>
          </div>
        </div>
      {%- endif -%}

      <div class="drawer__header zcart__header">
        <h2 class="drawer__heading zcart__heading">
          Mon panier
          {%- if cart.item_count > 0 -%}
            <span class="zcart__count">• {{ cart.item_count }} article{% if cart.item_count > 1 %}s{% endif %}</span>
          {%- endif -%}
        </h2>
        <button
          class="drawer__close zcart__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <span class="svg-wrapper">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>

      <cart-drawer-items
        class="zcart__items{% if cart == empty %} is-empty{% endif %}"
      >
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents zcart__list">
            {%- for item in cart.items -%}
              {%- liquid
                assign zcart_idx = item.index | plus: 1
                assign zcart_has_compare = false
                if item.variant.compare_at_price > item.variant.price
                  assign zcart_has_compare = true
                  assign zcart_savings = item.variant.compare_at_price | minus: item.variant.price | times: item.quantity
                endif
                assign has_qty_rules = false
                if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
                  assign has_qty_rules = true
                endif
                assign zcart_is_gift = false
                if item.properties['Cadeau']
                  assign zcart_is_gift = true
                endif
              -%}
              <div
                id="CartDrawer-Item-{{ zcart_idx }}"
                class="cart-item zcart__row{% if item.parent_relationship.parent != null %} cart-item__nested-line{% endif %}"
              >
                <div class="zcart__row-media">
                  {%- if item.image -%}
                    <a href="{{ item.url }}" class="cart-item__link" tabindex="-1" aria-hidden="true"> </a>
                    <img
                      class="cart-item__image"
                      src="{{ item.image | image_url: width: 300 }}"
                      alt="{{ item.image.alt | escape }}"
                      loading="lazy"
                      width="150"
                      height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}"
                    >
                  {%- endif -%}
                </div>

                <div class="zcart__row-main">
                  <div class="zcart__row-top">
                    <a href="{{ item.url }}" class="cart-item__name zcart__row-title break">
                      {{- item.product.title | escape -}}
                    </a>
                    <cart-remove-button
                      id="CartDrawer-Remove-{{ zcart_idx }}"
                      data-index="{{ zcart_idx }}"
                      class="zcart__row-remove{% if item.properties['Cadeau'] %} hidden{% endif %}"
                    >
                      <button
                        type="button"
                        class="button button--tertiary cart-remove-button"
                        aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                        data-variant-id="{{ item.variant.id }}"
                      >
                        <span class="svg-wrapper">
                          {{- 'icon-remove.svg' | inline_asset_content -}}
                        </span>
                      </button>
                    </cart-remove-button>
                  </div>

                  {%- if item.product.has_only_default_variant == false -%}
                    <div class="zcart__row-options">
                      {%- for option in item.options_with_values -%}
                        <span>{{ option.name }}: {{ option.value }}{% unless forloop.last %}, {% endunless %}</span>
                      {%- endfor -%}
                    </div>
                  {%- endif -%}

                  <div class="zcart__row-bottom">
                    <quantity-popover>
                      <div class="cart-item__quantity-wrapper quantity-popover-wrapper">
                        <div class="quantity-popover-container">
                          <quantity-input class="quantity cart-quantity zcart__stepper">
                            <button
                              class="quantity__button"
                              name="minus"
                              type="button"
                              {% if zcart_is_gift or item.instructions and item.instructions.can_update_quantity == false %}
                                disabled
                              {% endif %}
                            >
                              <span class="visually-hidden">
                                {{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}
                              </span>
                              <span class="svg-wrapper">
                                {{- 'icon-minus.svg' | inline_asset_content -}}
                              </span>
                            </button>
                            <input
                              class="quantity__input"
                              type="number"
                              data-quantity-variant-id="{{ item.variant.id }}"
                              name="updates[]"
                              value="{{ item.quantity }}"
                              {% # theme-check-disable %}
                              data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                              min="0"
                              data-min="{{ item.variant.quantity_rule.min }}"
                              {% if item.variant.quantity_rule.max != null %}
                                max="{{ item.variant.quantity_rule.max }}"
                              {% endif %}
                              step="{{ item.variant.quantity_rule.increment }}"
                              {% # theme-check-enable %}
                              aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                              id="Drawer-quantity-{{ zcart_idx }}"
                              data-index="{{ zcart_idx }}"
                              {% if zcart_is_gift or item.instructions and item.instructions.can_update_quantity == false %}
                                disabled
                              {% endif %}
                            >
                            <button
                              class="quantity__button"
                              name="plus"
                              type="button"
                              {% if zcart_is_gift or item.instructions and item.instructions.can_update_quantity == false %}
                                disabled
                              {% endif %}
                            >
                              <span class="visually-hidden">
                                {{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}
                              </span>
                              <span class="svg-wrapper">
                                {{- 'icon-plus.svg' | inline_asset_content -}}
                              </span>
                            </button>
                          </quantity-input>
                        </div>
                      </div>
                      <div
                        id="CartDrawer-LineItemError-{{ zcart_idx }}"
                        class="cart-item__error"
                        role="alert"
                      >
                        <small class="cart-item__error-text"></small>
                        <span class="svg-wrapper">
                          {{- 'icon-error.svg' | inline_asset_content -}}
                        </span>
                      </div>
                    </quantity-popover>

                    <div class="zcart__row-price">
                      {%- render 'loading-spinner' -%}
                      {%- if zcart_has_compare -%}
                        <s class="zcart__price-old">{{ item.variant.compare_at_price | times: item.quantity | money }}</s>
                        <span class="zcart__price-now">{{ item.final_line_price | money }}</span>
                      {%- else -%}
                        <span class="zcart__price-now">{{ item.final_line_price | money }}</span>
                      {%- endif -%}
                    </div>
                  </div>

                  {%- if zcart_has_compare -%}
                    <p class="zcart__row-savings">(Tu économises {{ zcart_savings | money }})</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
          <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
          <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
            {{ 'accessibility.loading' | t }}
          </p>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
      </cart-drawer-items>

      <div class="drawer__footer zcart__footer">
        <div class="cart-drawer__footer">
          {%- if cart != empty -%}
            {% render 'zooryn-cart-crosssell' %}
          {%- endif -%}
          {%- liquid
            assign zcart_total_savings = 0
            for item in cart.items
              if item.variant.compare_at_price > item.variant.price
                assign zcart_item_savings = item.variant.compare_at_price | minus: item.variant.price | times: item.quantity
                assign zcart_total_savings = zcart_total_savings | plus: zcart_item_savings
              endif
            endfor
          -%}
          <div class="zcart__totals">
            {%- if zcart_total_savings > 0 -%}
              <div class="zcart__totals-row zcart__totals-row--savings">
                <span>Économies</span>
                <span>-{{ zcart_total_savings | money }}</span>
              </div>
            {%- endif -%}
            <div class="zcart__totals-row zcart__totals-row--subtotal">
              <span>Sous-total</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
          </div>
        </div>

        <div class="cart__ctas zcart__ctas">
          <button
            type="submit"
            id="CartDrawer-Checkout"
            class="cart__checkout-button zcart__checkout button"
            name="checkout"
            form="CartDrawer-Form"
            {% if cart == empty %}
              disabled
            {% endif %}
          >
            Passer la commande
          </button>
        </div>

        <p class="zcart__guarantee">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="16" height="16">
            <path d="M12 2L4 5v6c0 5 3.4 8.7 8 10 4.6-1.3 8-5 8-10V5l-8-3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
            <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          Garantie satisfait ou remboursé 30 jours
        </p>
      </div>
    </div>
  </div>
</cart-drawer>

{%- comment -%}
  ===========================================================================
  Sculpted — Section "Contact" (page contact)
  ---------------------------------------------------------------------------
  Recréation Shopify de la maquette "Sculpted Contact.html".
  - Intro "Questions?" + coordonnées (email, SAV, délai de réponse)
  - Formulaire de contact NATIF Shopify ({% form 'contact' %}) : les messages
    arrivent sur l'email admin de la boutique, aucun service externe requis.
  - Tous les textes sont éditables dans le personnalisateur Shopify (schema).

  Header / footer / ticker viennent du thème, pas de cette section.
  Les badges de confiance sont une section séparée (sculpted-trust-badges).
  ===========================================================================
{%- endcomment -%}

{%- comment -%} Police Archivo (identique à la maquette). À retirer si le thème la charge déjà. {%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

<section class="dfy-contact" id="dfy-contact-{{ section.id }}">
  <div class="dfy-wrap dfy-contact-grid">

    {%- comment -%} ---------- Intro + coordonnées ---------- {%- endcomment -%}
    <div class="dfy-contact-intro">
      <h1 class="dfy-display">{{ section.settings.heading | escape }}</h1>
      <p>{{ section.settings.intro | escape }}</p>
      {%- if section.settings.email != blank -%}
        <a href="mailto:{{ section.settings.email }}" class="dfy-mail">{{ section.settings.email }}</a>
      {%- endif -%}

      <div class="dfy-contact-meta">
        {%- if section.settings.meta1_label != blank -%}
          <div class="dfy-row">
            <svg class="dfy-ic" viewBox="0 0 24 24"><path d="M4 5h16v14H4z"/><path d="M4 6l8 6 8-6"/></svg>
            <div><b>{{ section.settings.meta1_label | escape }}</b><span>{{ section.settings.meta1_value | escape }}</span></div>
          </div>
        {%- endif -%}
        {%- if section.settings.meta2_label != blank -%}
          <div class="dfy-row">
            <svg class="dfy-ic" viewBox="0 0 24 24"><path d="M4 13a8 8 0 0116 0M4 13v3a2 2 0 002 2M20 13v3a2 2 0 01-2 2h-3"/></svg>
            <div><b>{{ section.settings.meta2_label | escape }}</b><span>{{ section.settings.meta2_value | escape }}</span></div>
          </div>
        {%- endif -%}
        {%- if section.settings.meta3_label != blank -%}
          <div class="dfy-row">
            <svg class="dfy-ic" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
            <div><b>{{ section.settings.meta3_label | escape }}</b><span>{{ section.settings.meta3_value | escape }}</span></div>
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ---------- Formulaire contact natif Shopify ---------- {%- endcomment -%}
    <div class="dfy-form-card">
      {%- form 'contact', id: 'dfy-contact-form' -%}
        {%- if form.posted_successfully? -%}
          <p class="dfy-sent-note dfy-sent-note--show">{{ section.settings.success_text | escape }}</p>
        {%- elsif form.errors -%}
          <p class="dfy-error-note">{{ form.errors | default_errors }}</p>
        {%- endif -%}

        <div class="dfy-form-grid">
          <div class="dfy-field">
            <label for="dfy-name">{{ section.settings.label_name | escape }}</label>
            <input type="text" id="dfy-name" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" placeholder="{{ section.settings.ph_name | escape }}" required>
          </div>
          <div class="dfy-field">
            <label for="dfy-email">{{ section.settings.label_email | escape }}</label>
            <input type="email" id="dfy-email" name="contact[email]" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" placeholder="{{ section.settings.ph_email | escape }}" required>
          </div>
        </div>
        <div class="dfy-field dfy-form-msg">
          <label for="dfy-message">{{ section.settings.label_message | escape }}</label>
          <textarea id="dfy-message" name="contact[body]" placeholder="{{ section.settings.ph_message | escape }}" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>
        <button type="submit" class="dfy-btn dfy-btn-primary">{{ section.settings.button_label | escape }}</button>
      {%- endform -%}
    </div>

  </div>
</section>

{% stylesheet %}
/* ---------- TOKENS (identiques à la maquette Sculpted, préfixés --dfy- pour
   ne pas entrer en conflit avec les variables du thème) ------------------ */
.dfy-contact{
  --dfy-ink:#101114;
  --dfy-paper:#ffffff;
  --dfy-soft:#f4f5f7;
  --dfy-muted:#73777e;
  --dfy-line:#e6e8eb;
  --dfy-accent:#1496d6;
  --dfy-ok:#1f9d57;
  --dfy-warn:#d2473c;
  --dfy-maxw:1180px;
  --dfy-gutter:24px;
  --dfy-r:14px;
  --dfy-t-h1:clamp(38px, 5.6vw, 76px);
  --dfy-t-body:17px;
  font-family:'Archivo',system-ui,sans-serif;
  color:var(--dfy-ink);
  font-size:var(--dfy-t-body);
  line-height:1.55;
  -webkit-font-smoothing:antialiased;
}
.dfy-contact *{box-sizing:border-box}
.dfy-wrap{max-width:var(--dfy-maxw);margin:0 auto;padding:0 var(--dfy-gutter)}
.dfy-display{font-weight:900;line-height:1.02;letter-spacing:-.01em}

/* ---------- Section contact ---------- */
.dfy-contact{padding:96px 0 110px}
.dfy-contact-grid{display:grid;grid-template-columns:1fr 1.15fr;gap:72px;align-items:start}
.dfy-contact-intro h1{font-size:var(--dfy-t-h1);margin:0 0 28px}
.dfy-contact-intro p{color:var(--dfy-muted);font-size:18px;max-width:34ch;margin:0 0 30px}
.dfy-mail{font-weight:700;color:var(--dfy-ink);text-decoration:underline;text-underline-offset:4px}
.dfy-contact-meta{margin-top:40px;display:flex;flex-direction:column;gap:20px}
.dfy-contact-meta .dfy-row{display:flex;align-items:center;gap:14px}
.dfy-contact-meta .dfy-row .dfy-ic{width:22px;height:22px;stroke:var(--dfy-accent);fill:none;stroke-width:1.7;flex:none}
.dfy-contact-meta .dfy-row b{display:block;font-size:15px}
.dfy-contact-meta .dfy-row span{font-size:14px;color:var(--dfy-muted)}

/* ---------- Carte formulaire ---------- */
.dfy-form-card{background:var(--dfy-soft);border-radius:var(--dfy-r);padding:40px}
.dfy-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px}
.dfy-field label{display:block;font-size:12px;font-weight:700;letter-spacing:.08em;
  text-transform:uppercase;color:var(--dfy-muted);margin-bottom:8px}
.dfy-field input,.dfy-field textarea{
  width:100%;background:#fff;border:1px solid var(--dfy-line);border-radius:10px;
  padding:15px 16px;font-family:inherit;font-size:15px;color:var(--dfy-ink);outline:none;
  transition:border-color .15s, box-shadow .15s;
}
.dfy-field input:focus,.dfy-field textarea:focus{
  border-color:var(--dfy-accent);box-shadow:0 0 0 3px rgba(20,150,214,.12);
}
.dfy-field textarea{resize:vertical;min-height:150px}
.dfy-form-msg{margin-bottom:22px}

/* Bouton */
.dfy-btn{
  display:inline-flex;align-items:center;justify-content:center;gap:10px;
  font-weight:700;font-size:14px;letter-spacing:.08em;text-transform:uppercase;
  padding:18px 40px;border-radius:999px;border:none;cursor:pointer;
  font-family:inherit;transition:transform .15s ease, background .15s ease;
}
.dfy-btn:active{transform:translateY(1px)}
.dfy-btn-primary{background:var(--dfy-ink);color:#fff}
.dfy-btn-primary:hover{background:#000}

/* Note de confirmation / erreur (gérées par Shopify, pas de JS) */
.dfy-sent-note{color:var(--dfy-ok);font-weight:700;font-size:14px;margin:0 0 16px}
.dfy-sent-note--show{display:block}
.dfy-error-note{color:var(--dfy-warn);font-weight:700;font-size:14px;margin:0 0 16px}

/* ---------- Responsive ---------- */
@media (max-width:980px){
  .dfy-contact-grid{grid-template-columns:1fr;gap:44px}
}
@media (max-width:560px){
  .dfy-contact{padding:60px 0 70px}
  .dfy-form-grid{grid-template-columns:1fr}
  .dfy-form-card{padding:26px}
}
{% endstylesheet %}

{% schema %}
{
  "name": "Sculpted — Contact",
  "tag": "section",
  "class": "dfy-contact-wrapper",
  "settings": [
    { "type": "header", "content": "Intro" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Questions?" },
    { "type": "textarea", "id": "intro", "label": "Texte d'intro", "default": "Get in touch below, or email us anytime — we reply within 24 hours." },
    { "type": "text", "id": "email", "label": "Email affiché", "default": "contact@zooryn.com" },
    { "type": "header", "content": "Coordonnées (3 lignes)" },
    { "type": "text", "id": "meta1_label", "label": "Ligne 1 — titre", "default": "Email" },
    { "type": "text", "id": "meta1_value", "label": "Ligne 1 — valeur", "default": "contact@zooryn.com" },
    { "type": "text", "id": "meta2_label", "label": "Ligne 2 — titre", "default": "Customer service" },
    { "type": "text", "id": "meta2_value", "label": "Ligne 2 — valeur", "default": "Available 24/7" },
    { "type": "text", "id": "meta3_label", "label": "Ligne 3 — titre", "default": "Response time" },
    { "type": "text", "id": "meta3_value", "label": "Ligne 3 — valeur", "default": "Within 24 hours" },
    { "type": "header", "content": "Formulaire" },
    { "type": "text", "id": "label_name", "label": "Label — Nom", "default": "Name" },
    { "type": "text", "id": "ph_name", "label": "Placeholder — Nom", "default": "Your name" },
    { "type": "text", "id": "label_email", "label": "Label — Email", "default": "Email" },
    { "type": "text", "id": "ph_email", "label": "Placeholder — Email", "default": "you@email.com" },
    { "type": "text", "id": "label_message", "label": "Label — Message", "default": "Message" },
    { "type": "text", "id": "ph_message", "label": "Placeholder — Message", "default": "How can we help?" },
    { "type": "text", "id": "button_label", "label": "Bouton", "default": "Send message" },
    { "type": "textarea", "id": "success_text", "label": "Message de confirmation", "default": "Thanks — your message is on its way. We'll be in touch within 24 hours." }
  ],
  "presets": [
    { "name": "Sculpted — Contact" }
  ]
}
{% endschema %}

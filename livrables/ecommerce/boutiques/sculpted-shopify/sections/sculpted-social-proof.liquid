{%- comment -%}
  Sculpted — Preuve sociale / témoignages.
  - Titre + ligne de note + lien Trustpilot, éditables.
  - 1 bloc par témoignage : image (ou cadre), nom, citation.
{%- endcomment -%}
<section class="proof tint center">
  <div class="wrap">
    <h2 class="lead display" style="text-transform:none">{{ section.settings.heading | escape }}</h2>
    <div class="proof-trust">
      <div class="trust"><span>{{ section.settings.rating_label }} <b>{{ section.settings.rating_value | escape }}</b></span><span class="stars" style="color:#00b67a">★★★★★</span></div>
      <a href="{{ section.settings.link_url | default: '#' }}">{{ section.settings.link_label | escape }}</a>
    </div>
    <div class="tcards">
      {%- for block in section.blocks -%}
        <div class="tcard" {{ block.shopify_attributes }}>
          <div class="frame{% if block.settings.image != blank %} has-img{% endif %}">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 1254 }}" alt="{{ block.settings.name | escape }}" width="1254" height="1254" loading="lazy">
            {%- else -%}
              <span>1254 × 1254</span>
            {%- endif -%}
          </div>
          <div class="name">{{ block.settings.name | escape }}</div>
          <blockquote>{{ block.settings.quote | escape }}</blockquote>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sculpted — Preuve sociale",
  "tag": "section",
  "settings": [
    { "type": "textarea", "id": "heading", "label": "Titre", "default": "Over 10,000 men have regained their confidence. What about you?" },
    { "type": "text", "id": "rating_label", "label": "Texte note", "default": "Excellent" },
    { "type": "text", "id": "rating_value", "label": "Valeur note", "default": "4.8 / 5" },
    { "type": "text", "id": "link_label", "label": "Libellé lien", "default": "Verified reviews on Trustpilot" },
    { "type": "url", "id": "link_url", "label": "Lien" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Témoignage",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (1254 × 1254 px)" },
        { "type": "text", "id": "name", "label": "Nom", "default": "Andrew F. — 45" },
        { "type": "textarea", "id": "quote", "label": "Citation", "default": "Since I gained weight I refused family photos. This weekend I was in front of the camera for the first time in 4 years." }
      ]
    }
  ],
  "default": {
    "blocks": [
        { "type": "testimonial", "settings": { "name": "Andrew F. — 45", "quote": "Since I gained weight I refused family photos. This weekend I was in front of the camera for the first time in 4 years. My sister told me I looked fit." } },
        { "type": "testimonial", "settings": { "name": "Thomas R. — 33", "quote": "It's not just a tank top. After 3 months wearing it daily my posture completely changed and I lost weight without changing anything else. Colleagues asked if I'd started training. A real transformation." } },
        { "type": "testimonial", "settings": { "name": "Alex B. — 41", "quote": "I used to suck in my stomach in meetings without realizing it, for years. Exhausting. With Sculpted I don't think about it anymore. My shirt fits well and I've got my confidence back." } },
        { "type": "testimonial", "settings": { "name": "Michael D. — 38", "quote": "Honestly I didn't believe it. I always had this belly I hid under loose t-shirts. The first time I put it on my wife asked if I'd lost weight. I'd changed nothing." } },
        { "type": "testimonial", "settings": { "name": "Ryan M. — 29", "quote": "I expected nothing. After a month my relationship with the mirror completely changed. I'm not fighting my reflection anymore. It's the first time I feel good in my body." } }
    ]
  }
}
{% endschema %}

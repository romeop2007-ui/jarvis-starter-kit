{%- assign visible_init = 8 -%}
{%- comment -%} Photos des 13 premiers avis, uploadées dans Shopify > Fichiers (1.jpg..13.jpg).
   Ratio réel conservé (pas de recadrage carré). {%- endcomment -%}
{%- assign cdn = "https://cdn.shopify.com/s/files/1/1007/2988/0921/files/" -%}

<div class="zsac avis" id="zsac-avis">
  <div class="wrap">
    <div class="avis-entete">
      {%- assign score = s.score | default: '4,8' -%}
      {%- assign score_pct = score | replace: ',', '.' | times: 1.0 | divided_by: 5.0 | times: 100 -%}
      <div class="avis-score">
        <span class="stars-frac" style="font-size:22px"><span class="bg">★★★★★</span><span class="fg" style="width:{{ score_pct }}%">★★★★★</span></span>
        <span class="avis-count">{{ s.score_sub | default: '101 avis' }}</span>
      </div>
    </div>

    <div class="avis-liste" id="zsacAvisListe-{{ sid }}">
      {%- for row in rows -%}
        {%- assign f = row | split: "~" -%}
        {%- assign note = f[0] | times: 1 -%}
        {%- assign idx = forloop.index -%}
        {%- assign has_photo = false -%}
        {%- if idx <= 13 -%}{%- assign has_photo = true -%}{%- endif -%}
        {%- assign imgkey = 'avis_img_' | append: idx -%}
        {%- assign rimg = section.settings[imgkey] -%}
        <div class="avis-carte{% if has_photo %} photo{% endif %}{% if idx > visible_init %} hide extra{% endif %}">
          <div class="avis-corps">
            <div class="top"><span class="nom">{{ f[1] }}</span><span class="verifie">✓ Vérifié</span></div>
            <div class="avis-date">{{ f[2] }}</div>
            <div class="etoiles">{% for i in (1..5) %}{% if i <= note %}★{% else %}☆{% endif %}{% endfor %}</div>
            <p>{{ f[3] }}</p>
            {%- if f[4] and f[4] != blank -%}<div class="avis-variante"><span>Variante :</span> {{ f[4] | strip }}</div>{%- endif -%}
          </div>
          {%- if has_photo -%}
            <div class="avis-photo">
              {%- if rimg != blank -%}
                <img class="avis-thumb zsl-open" src="{{ rimg | image_url: width: 320 }}" data-full="{{ rimg | image_url: width: 1400 }}" alt="Photo de {{ f[1] | escape }}" loading="lazy">
              {%- else -%}
                {%- assign rurl = cdn | append: idx | append: '.jpg' -%}
                <img class="avis-thumb zsl-open" src="{{ rurl }}?width=320" data-full="{{ rurl }}?width=1400" alt="Photo de {{ f[1] | escape }}" loading="lazy">
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="avis-plus"><button type="button" id="zsacAvisPlus-{{ sid }}">{{ s.more_label | default: "Voir plus d'avis" }}</button></div>
  </div>

  <!-- Popup avis (photo + détail de l'avis, façon Loox) -->
  <div class="zsl-modal" id="zslModal-{{ sid }}" aria-hidden="true">
    <div class="zsl-card">
      <button type="button" class="zsl-close" aria-label="Fermer">&times;</button>
      <img src="" alt="" class="zsl-img">
      <div class="zsl-body">
        <div class="zsl-top"><span class="zsl-nom"></span><span class="verifie">✓ Vérifié</span></div>
        <div class="zsl-mid"><span class="etoiles zsl-stars"></span><span class="zsl-date"></span></div>
        <p class="zsl-texte"></p>
        <div class="avis-variante zsl-var" style="display:none"></div>
      </div>
    </div>
  </div>
</div>

<script>
(function(){
  var liste = document.getElementById('zsacAvisListe-{{ sid }}');
  var plus = document.getElementById('zsacAvisPlus-{{ sid }}');
  var batch = 12;
  if(plus && liste){
    plus.addEventListener('click', function(){
      var caches = liste.querySelectorAll('.avis-carte.extra.hide');
      for(var i=0;i<caches.length && i<batch;i++){ caches[i].classList.remove('hide'); }
      if(liste.querySelectorAll('.avis-carte.extra.hide').length === 0){ plus.style.display='none'; }
    });
  }

  /* Popup avis : photo + détail complet de l'avis cliqué */
  var modal = document.getElementById('zslModal-{{ sid }}');
  if(modal){
    var mImg = modal.querySelector('.zsl-img');
    var closeBtn = modal.querySelector('.zsl-close');
    var mNom = modal.querySelector('.zsl-nom');
    var mStars = modal.querySelector('.zsl-stars');
    var mDate = modal.querySelector('.zsl-date');
    var mTexte = modal.querySelector('.zsl-texte');
    var mVar = modal.querySelector('.zsl-var');
    function open(t){
      var carte = t.closest('.avis-carte');
      mImg.src = t.getAttribute('data-full') || t.src;
      mImg.alt = t.getAttribute('alt') || '';
      if(carte){
        var nom = carte.querySelector('.nom');
        var stars = carte.querySelector('.etoiles');
        var date = carte.querySelector('.avis-date');
        var texte = carte.querySelector('.avis-corps p');
        var vart = carte.querySelector('.avis-variante');
        if(mNom){ mNom.textContent = nom ? nom.textContent : ''; }
        if(mStars){ mStars.textContent = stars ? stars.textContent : ''; }
        if(mDate){ mDate.textContent = date ? date.textContent : ''; }
        if(mTexte){ mTexte.textContent = texte ? texte.textContent : ''; }
        if(mVar){
          if(vart){ mVar.innerHTML = vart.innerHTML; mVar.style.display = ''; }
          else { mVar.innerHTML = ''; mVar.style.display = 'none'; }
        }
      }
      modal.classList.add('open'); modal.setAttribute('aria-hidden','false');
      document.body.style.overflow = 'hidden';
    }
    function close(){
      modal.classList.remove('open'); modal.setAttribute('aria-hidden','true');
      document.body.style.overflow = ''; mImg.src = '';
    }
    /* Toute la carte d'un avis à photo est cliquable, pas seulement l'image */
    document.getElementById('zsac-avis').addEventListener('click', function(e){
      var carte = e.target.closest('.avis-carte.photo');
      if(!carte){ return; }
      var t = carte.querySelector('.zsl-open');
      if(t){ open(t); }
    });
    modal.addEventListener('click', function(e){ if(e.target === modal || e.target === closeBtn){ close(); } });
    document.addEventListener('keydown', function(e){ if(e.key === 'Escape' && modal.classList.contains('open')){ close(); } });
  }
})();
</script>


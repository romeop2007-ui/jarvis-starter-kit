{%- comment -%} ZOORYN — Matelas : bloc bénéfice "intro" (titre + 3 colonnes + image large). {%- endcomment -%}
{%- assign s = section.settings -%}
<div class="zmat">
  <section class="feature{% if s.alt_bg %} alt{% endif %}">
    <div class="wrap">
      {%- if s.heading != blank -%}
        <div class="feature-head reveal"><h2>{{ s.heading }}</h2></div>
      {%- endif -%}
      <div class="intro-cols reveal">
        {%- if s.col1 != blank -%}<h3>{{ s.col1 }}</h3>{%- endif -%}
        {%- if s.col2 != blank -%}<h3>{{ s.col2 }}</h3>{%- endif -%}
        {%- if s.col3 != blank -%}<h3>{{ s.col3 }}</h3>{%- endif -%}
      </div>
      <div class="feature-img-wide reveal">
        {%- if s.image != blank -%}
          <img class="img-cover" src="{{ s.image | image_url: width: 1400 }}" alt="{{ s.image.alt | escape }}" loading="lazy" width="1400" height="788">
        {%- else -%}
          <div class="placeholder" style="aspect-ratio:16/9;"><span>{{ s.placeholder_label | default: 'Démonstration en situation' }}</span></div>
        {%- endif -%}
      </div>
    </div>
  </section>
</div>
{% schema %}
{
  "name": "Matelas — Bloc intro",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "alt_bg", "label": "Fond crème foncé", "default": false },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Déroulez, gonflez, profitez !" },
    { "type": "textarea", "id": "col1", "label": "Colonne 1", "default": "Laissez le stress de la ville derrière vous et savourez le calme de la nature, en famille." },
    { "type": "textarea", "id": "col2", "label": "Colonne 2", "default": "Grâce à la pompe intégrée efficace, le lit est prêt en un instant – parfait quand les enfants ont besoin de bouger." },
    { "type": "textarea", "id": "col3", "label": "Colonne 3", "default": "Au matin, vous enroulez le matelas en un tour de main : plus de temps pour un petit-déjeuner cosy au coin du feu." },
    { "type": "image_picker", "id": "image", "label": "Image large" },
    { "type": "text", "id": "placeholder_label", "label": "Texte du damier (si pas d'image)", "default": "Démonstration en situation — famille en camping, matelas déroulé" }
  ],
  "presets": [ { "name": "Matelas — Bloc intro" } ]
}
{% endschema %}

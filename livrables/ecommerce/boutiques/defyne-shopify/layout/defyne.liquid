{%- comment -%}
  ===========================================================================
  Defyne — Layout isolé (gabarit de page autonome)
  ---------------------------------------------------------------------------
  Layout MINIMAL qui n'inclut PAS le header/footer du thème Shopify.
  Il sert à rendre les pages Defyne (contact, etc.) exactement comme la
  maquette Claude Design, sans interférence du thème en place.

  À utiliser via la 1re ligne d'un template :  {% layout 'defyne' %}
  ===========================================================================
{%- endcomment -%}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#101114">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  {{ content_for_header }}
</head>
<body>
  {{ content_for_layout }}
</body>
</html>

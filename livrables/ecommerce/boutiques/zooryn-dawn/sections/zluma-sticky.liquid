{%- comment -%}
  ZOORYN — Guirlande Luma : barre d'achat collante. Le prix affiché est
  synchronisé en JS sur le palier de bundle sélectionné dans la buy box
  (voir zluma-buybox.liquid, fonction syncSticky).
{%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign sid = section.id -%}
<div class="zluma">
  <div class="zluma-sticky-cta" id="zlumaSticky-{{ sid }}">
    <div class="sticky-inner">
      <div>
        <p class="sticky-title" id="zlumaStickyTitle">{{ s.title | default: 'Luma – Guirlande Lumineuse Solaire' }}</p>
        <div class="sticky-price">
          <span class="now" id="zlumaStickyPrice"></span>
          <span class="old" id="zlumaStickyOld"></span>
          <span class="save" id="zlumaStickySave"></span>
        </div>
      </div>
      <button type="button" class="btn-cart" id="zlumaStickyBtn-{{ sid }}">{{ s.cta_label | default: 'Ajouter au panier' }}</button>
    </div>
  </div>
</div>

<script>
(function(){
  var sticky = document.getElementById('zlumaSticky-{{ sid }}');
  if(!sticky){ return; }
  var btn = document.getElementById('zlumaStickyBtn-{{ sid }}');
  if(btn){
    btn.addEventListener('click', function(){
      if(window.zlumaAddToCart){ window.zlumaAddToCart(true); }
      else { window.location.href = '{{ routes.cart_url }}'; }
    });
  }
  var hero = document.querySelector('[id^="zluma-buybox-"]');
  var footer = document.querySelector('.footer') || document.querySelector('footer');
  if(hero){
    window.addEventListener('scroll', function(){
      var rect = hero.getBoundingClientRect();
      var pastHero = rect.bottom < 0;
      // Masquer la barre dès que le footer entre dans l'écran, pour le laisser
      // entièrement visible (sinon la barre fixe recouvre son bas).
      var footerVisible = false;
      if(footer){
        var fRect = footer.getBoundingClientRect();
        footerVisible = fRect.top < window.innerHeight;
      }
      if(pastHero && !footerVisible){ sticky.classList.add('show'); }
      else { sticky.classList.remove('show'); }
    });
  }
})();
</script>

{% schema %}
{
  "name": "Luma — Barre collante",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Titre", "default": "Luma – Guirlande Lumineuse Solaire" },
    { "type": "text", "id": "cta_label", "label": "Texte du bouton", "default": "Ajouter au panier" }
  ],
  "presets": [ { "name": "Luma — Barre collante" } ]
}
{% endschema %}

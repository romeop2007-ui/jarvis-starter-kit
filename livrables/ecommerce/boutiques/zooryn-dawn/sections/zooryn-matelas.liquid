<script>
(function(){
  var root = document.currentScript.previousElementSibling;
  while(root && !root.classList.contains('zmat')){ root = root.previousElementSibling; }
  if(!root){ root = document.querySelector('.zmat'); }

  /* Galerie : changer l'image principale au clic sur une vignette */
  root.querySelectorAll('.thumb').forEach(function(t){
    t.addEventListener('click', function(){
      root.querySelectorAll('.thumb').forEach(function(x){ x.classList.remove('active'); });
      t.classList.add('active');
      var label = t.querySelector('span').textContent || 'Photo produit';
      root.querySelector('#mainImage span').textContent = label;
    });
  });

  /* Sélecteur de bundles */
  root.querySelectorAll('[data-bundle]').forEach(function(card){
    card.addEventListener('click', function(){
      root.querySelectorAll('[data-bundle]').forEach(function(c){ c.classList.remove('selected'); });
      card.classList.add('selected');
    });
  });

  /* Add-on */
  var addon = root.querySelector('#bundleAddon');
  if(addon){ addon.addEventListener('click', function(){ addon.classList.toggle('selected'); }); }

  /* Avis : onglets */
  root.querySelectorAll('.review-tab').forEach(function(tab){
    tab.addEventListener('click', function(){
      root.querySelectorAll('.review-tab').forEach(function(t){ t.classList.remove('active'); });
      tab.classList.add('active');
    });
  });

  /* Avis : charger plus */
  var btnMore = root.querySelector('#btnMoreReviews');
  if(btnMore){
    btnMore.addEventListener('click', function(){
      root.querySelectorAll('#reviewsGrid .review-card.is-hidden').forEach(function(c){ c.classList.remove('is-hidden'); });
      btnMore.style.display = 'none';
    });
  }

  /* FAQ : accordéon */
  root.querySelectorAll('.faq-q').forEach(function(q){
    q.addEventListener('click', function(){
      var item = q.closest('.faq-item');
      var ans = item.querySelector('.faq-a');
      if(item.classList.contains('open')){
        item.classList.remove('open');
        ans.style.maxHeight = null;
      } else {
        item.classList.add('open');
        ans.style.maxHeight = ans.scrollHeight + 'px';
      }
    });
  });

  /* Sticky CTA */
  var stickyCta = root.querySelector('#stickyCta');
  var heroBtn = root.querySelector('.product .btn-cart');
  var stickyBtn = root.querySelector('#stickyCartBtn');
  var heroForm = root.querySelector('#zmatForm');
  if(stickyBtn){
    stickyBtn.addEventListener('click', function(){
      if(heroForm){ heroForm.submit(); }
      else { window.location.href = '{{ routes.cart_url }}'; }
    });
  }
  if(stickyCta && heroBtn){
    window.addEventListener('scroll', function(){
      var rect = heroBtn.getBoundingClientRect();
      if(rect.bottom < 0){ stickyCta.classList.add('show'); }
      else{ stickyCta.classList.remove('show'); }
    });
  }

  /* Animations au scroll */
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, { threshold:0.12 });
  root.querySelectorAll('.reveal').forEach(function(el){ io.observe(el); });
})();
</script>


{%- comment -%}
  ZOORYN — Guirlande Luma : photos clients (grille 3×2). Données en dur,
  prénoms francisés. Roméo peut uploader une photo par carte (pic1..pic6).
{%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign rows = "Camille R.~La tente la plus cosy de tout le camping.~Tout le monde s'arrêtait pour demander ce qu'on avait fait. Environ deux minutes à installer.~guirlande autour d'une tente ||| J.K.~Je l'emporte à chaque camping maintenant.~Se charge au soleil et s'enroule en quelques secondes. Complètement différente des autres lampes.~camping avec guirlande ||| Manon~Assis jusqu'à minuit.~Accrochée entre les arbres. Personne ne voulait rentrer. Ça dit tout.~guirlande dans les arbres ||| Sarah-Léna W.~Fonctionne partout.~Terrasse, balcon, camping. S'allume chaque soir automatiquement. J'en ai commandé deux de plus.~terrasse illuminée en soirée ||| Anne-Lise~Dîner sous le ciel ouvert.~La table du dîner a pris une toute autre dimension. Chaleureux, cosy, personne ne voulait aller se coucher.~repas en extérieur sous guirlande ||| T.H.~La tente ressemble à une chambre d'hôtel.~Quelques mètres le long de la paroi intérieure. La différence est énorme. On ne part plus camper sans elle.~intérieur tente éclairé" | split: " ||| " -%}

<div class="zluma">
  <section class="clients">
    <div class="wrap">
      <h2>{{ s.heading | default: 'Photos clients – Luma' }}</h2>
      <div class="clients-grid">
        {%- for row in rows -%}
          {%- assign f = row | split: "~" -%}
          {%- assign pickey = 'pic' | append: forloop.index -%}
          {%- assign img = s[pickey] -%}
          <div class="client-card">
            <div class="media">
              {%- if img != blank -%}
                <img class="img-cover" src="{{ img | image_url: width: 1254, height: 1254 }}" alt="{{ f[0] | escape }}" loading="lazy" width="1254" height="1254">
              {%- else -%}
                <div class="placeholder"><span>Photo client – {{ f[3] }}</span></div>
              {%- endif -%}
            </div>
            <div class="body">
              <span class="stars">★★★★★</span>
              <h3>« {{ f[1] }} »</h3>
              <p>« {{ f[2] }} »</p>
              <p class="author">– {{ f[0] }}</p>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Luma — Photos clients",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "Photos clients – Luma" },
    { "type": "paragraph", "content": "6 cartes en dur. Uploade une photo par carte (optionnel, sinon damier placeholder)." },
    { "type": "image_picker", "id": "pic1", "label": "Photo 1" },
    { "type": "image_picker", "id": "pic2", "label": "Photo 2" },
    { "type": "image_picker", "id": "pic3", "label": "Photo 3" },
    { "type": "image_picker", "id": "pic4", "label": "Photo 4" },
    { "type": "image_picker", "id": "pic5", "label": "Photo 5" },
    { "type": "image_picker", "id": "pic6", "label": "Photo 6" }
  ],
  "presets": [ { "name": "Luma — Photos clients" } ]
}
{% endschema %}

{%- comment -%}
  Zooryn — Avis clients PROTÈGE-TIBIAS (mur d'avis, page produit dédiée).
  Copie de sculpted-reviews avec un nom de section distinct : une section statique ne
  peut appartenir qu'à un seul template à la fois. Utilisée uniquement dans
  templates/product.shin-protectors.liquid → avis indépendants de la fiche Sculpted.
  Étoiles fixes à 5 et libellé "Verified" commun, comme la maquette.
{%- endcomment -%}
<section class="reviews">
  <div class="wrap">
    <p class="eyebrow center">{{ section.settings.eyebrow | escape }}</p>
    <h2 class="display">{{ section.settings.heading | escape }}</h2>
    <div class="rev-grid">
      {%- for block in section.blocks -%}
        <div class="rev{% if forloop.index > section.settings.visible_count %} rev--hidden{% endif %}" {{ block.shopify_attributes }}>
          <div class="top"><span class="stars">★★★★★</span><span class="ver">{{ section.settings.verified_label }}</span></div>
          <p>{{ block.settings.text | escape }}</p>
          <div class="who"><b>{{ block.settings.name | escape }}</b><span>{{ block.settings.date | escape }}</span></div>
        </div>
      {%- endfor -%}
    </div>
    {%- assign hidden_count = section.blocks.size | minus: section.settings.visible_count -%}
    {%- if section.settings.more_label != blank and hidden_count > 0 -%}
      <div class="rev-more"><button type="button" class="btn btn-ghost" data-rev-more="{{ section.id }}">{{ section.settings.more_label | escape }}</button></div>
    {%- endif -%}
  </div>
</section>

<style>#shopify-section-{{ section.id }} .rev--hidden{display:none}</style>

<script>
/* "Load more reviews" : révèle les avis cachés puis retire le bouton. */
(function(){
  var uid = {{ section.id | json }};
  var btn = document.querySelector('[data-rev-more="' + uid + '"]');
  if(!btn){ return; }
  btn.addEventListener('click', function(){
    var root = document.getElementById('shopify-section-' + uid) || document;
    root.querySelectorAll('.rev--hidden').forEach(function(r){ r.classList.remove('rev--hidden'); });
    var wrap = btn.closest('.rev-more');
    if(wrap){ wrap.remove(); } else { btn.remove(); }
  });
})();
</script>


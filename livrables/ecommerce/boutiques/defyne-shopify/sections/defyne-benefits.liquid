{%- comment -%}
  Defyne — Bénéfices (2 colonnes d'atouts autour d'une image centrale).
  - Titre central éditable.
  - Image centrale optionnelle (sinon cadre placeholder).
  - 4 blocs "bénéfice" : les 2 premiers vont à gauche, les 2 suivants à droite.
    Titre sur 2 lignes : appuie sur Entrée dans le champ pour un retour à la ligne.
{%- endcomment -%}
<section class="benefits">
  <div class="wrap">
    <h2 class="display lead center">{{ section.settings.heading | escape }}</h2>
    <div class="benefits-grid">
      <div class="benefit-col">
        {%- for block in section.blocks -%}
          {%- if forloop.index <= 2 -%}
            <div class="benefit" {{ block.shopify_attributes }}>
              {% render 'defyne-benefit-icon', icon: block.settings.icon %}
              <h3>{{ block.settings.title | escape | newline_to_br }}</h3>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="frame{% if section.settings.image != blank %} has-img{% endif %}">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 900 }}" alt="{{ section.settings.image_alt | escape }}" loading="lazy">
        {%- else -%}
          <span>{{ section.settings.frame_label | escape }}</span>
        {%- endif -%}
      </div>

      <div class="benefit-col">
        {%- for block in section.blocks -%}
          {%- if forloop.index > 2 -%}
            <div class="benefit" {{ block.shopify_attributes }}>
              {% render 'defyne-benefit-icon', icon: block.settings.icon %}
              <h3>{{ block.settings.title | escape | newline_to_br }}</h3>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Defyne — Bénéfices",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "Your new secret weapon against the beer belly." },
    { "type": "image_picker", "id": "image", "label": "Image centrale" },
    { "type": "text", "id": "image_alt", "label": "Texte alternatif", "default": "Front of the Defyne tank" },
    { "type": "text", "id": "frame_label", "label": "Libellé du cadre (si pas d'image)", "default": "Product — front of the Defyne tank" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Bénéfice",
      "limit": 4,
      "settings": [
        { "type": "select", "id": "icon", "label": "Icône", "options": [
          { "value": "ribs", "label": "Côtes" },
          { "value": "shirt-check", "label": "T-shirt + coche" },
          { "value": "waves", "label": "Vagues" },
          { "value": "shirt", "label": "T-shirt" }
        ], "default": "ribs" },
        { "type": "textarea", "id": "title", "label": "Titre (2 lignes possibles)", "default": "Goodbye\nbeer belly" }
      ]
    }
  ],
  "default": {
    "blocks": [
        { "type": "benefit", "settings": { "icon": "ribs", "title": "Goodbye\nbeer belly" } },
        { "type": "benefit", "settings": { "icon": "shirt-check", "title": "Invisible.\nUnstoppable." } },
        { "type": "benefit", "settings": { "icon": "waves", "title": "Bloated\nstomach? Gone." } },
        { "type": "benefit", "settings": { "icon": "shirt", "title": "Man boobs?\nFlattened." } }
    ]
  }
}
{% endschema %}

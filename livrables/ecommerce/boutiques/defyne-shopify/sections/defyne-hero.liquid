{%- comment -%}
  Defyne — Hero (haut de la homepage).
  - Titre en 2 parties : texte normal + "pilule" bleue.
  - Ligne d'avis (étoiles fixes + 2 textes éditables).
  - 3 atouts (blocs) avec choix d'icône.
  - Image de fond optionnelle : si tu en uploades une, elle remplit le hero ;
    sinon le cadre rayé de la maquette s'affiche, avec son libellé.
{%- endcomment -%}
<section class="hero">
  <div class="frame hero-frame{% if section.settings.image != blank %} has-img{% endif %}">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1800 }}" alt="{{ section.settings.image_alt | escape }}" loading="eager" width="1800" height="1200">
    {%- endif -%}
    <div class="hero-inner" style="position:relative;z-index:1">
      <h1 class="display">{{ section.settings.heading | escape }} <span class="pill">{{ section.settings.heading_pill | escape }}</span></h1>
      <div class="trust">
        <span class="stars">★★★★★</span>
        <b>{{ section.settings.rating | escape }}</b>
        <span style="color:var(--muted)">|</span>
        <b>{{ section.settings.reviews_count | escape }}</b>
      </div>
      <div class="hero-feats">
        {%- for block in section.blocks -%}
          <div class="feat" {{ block.shopify_attributes }}>
            {%- case block.settings.icon -%}
              {%- when 'bolt' -%}<svg class="ic" viewBox="0 0 24 24"><path d="M13 2L4 14h7l-1 8 9-12h-7z"/></svg>
              {%- when 'body' -%}<svg class="ic" viewBox="0 0 24 24"><path d="M8 3h8M9 3c0 4-3 5-3 9a6 6 0 0012 0c0-4-3-5-3-9"/></svg>
              {%- when 'sun' -%}<svg class="ic" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M19 5l-2 2M7 17l-2 2"/></svg>
              {%- else -%}<svg class="ic" viewBox="0 0 24 24"><path d="M5 12l5 5L20 7"/></svg>
            {%- endcase -%}
            <p>{{ block.settings.text | escape }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
    {%- if section.settings.image == blank -%}
      <span style="position:absolute;top:18px;left:50%;transform:translateX(-50%)">{{ section.settings.frame_label | escape }}</span>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Defyne — Hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "A physical transformation" },
    { "type": "text", "id": "heading_pill", "label": "Titre — partie en bleu", "default": "in one tank top" },
    { "type": "text", "id": "rating", "label": "Note", "default": "Excellent 4.8/5" },
    { "type": "text", "id": "reviews_count", "label": "Nombre d'avis", "default": "10,310+ Reviews" },
    { "type": "header", "content": "Image de fond (optionnelle)" },
    { "type": "image_picker", "id": "image", "label": "Image du hero" },
    { "type": "text", "id": "image_alt", "label": "Texte alternatif de l'image", "default": "Man wearing the Defyne tank" },
    { "type": "text", "id": "frame_label", "label": "Libellé du cadre (si pas d'image)", "default": "Hero — man wearing the Defyne tank" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Atout",
      "limit": 3,
      "settings": [
        { "type": "select", "id": "icon", "label": "Icône", "options": [
          { "value": "bolt", "label": "Éclair" },
          { "value": "body", "label": "Silhouette" },
          { "value": "sun", "label": "Confort / soleil" },
          { "value": "check", "label": "Coche" }
        ], "default": "bolt" },
        { "type": "text", "id": "text", "label": "Texte", "default": "Instant effect when you put it on" }
      ]
    }
  ],
  "default": {
    "blocks": [
        { "type": "feature", "settings": { "icon": "bolt", "text": "Instant effect when you put it on" } },
        { "type": "feature", "settings": { "icon": "body", "text": "Slimmer silhouette" } },
        { "type": "feature", "settings": { "icon": "sun", "text": "All-day comfort" } }
    ]
  }
}
{% endschema %}

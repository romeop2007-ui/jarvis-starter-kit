{%- comment -%}
  Defyne — Guide des tailles. L'ancre #size correspond au lien "Size guide" de la buy box.
  Chaque taille est un bloc (taille + plage de poids).
{%- endcomment -%}
<section class="size" id="size">
  <div class="wrap">
    <div class="size-grid">
      <div>
        <h2 class="display">{{ section.settings.heading | escape }}</h2>
        <table class="size-table">
          {%- for block in section.blocks -%}
            <tr {{ block.shopify_attributes }}><td>{{ block.settings.size | escape }}</td><td>{{ block.settings.range | escape }}</td></tr>
          {%- endfor -%}
        </table>
        {%- if section.settings.tip != blank -%}<p class="tip">{{ section.settings.tip | escape }}</p>{%- endif -%}
      </div>
      <div class="frame{% if section.settings.image != blank %} has-img{% endif %}">
        {%- if section.settings.image != blank -%}<img src="{{ section.settings.image | image_url: width: 900 }}" alt="{{ section.settings.image_alt | escape }}" loading="lazy">{%- else -%}<span>{{ section.settings.frame_label | escape }}</span>{%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Defyne — Size guide",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "Defyne™ size guide" },
    { "type": "text", "id": "tip", "label": "Conseil", "default": "Tip: if you're at the top of a range, size up for better comfort." },
    { "type": "image_picker", "id": "image", "label": "Image de référence" },
    { "type": "text", "id": "image_alt", "label": "Texte alternatif", "default": "Defyne worn front view" },
    { "type": "text", "id": "frame_label", "label": "Libellé cadre (si pas d'image)", "default": "Fit reference — Defyne worn front view" }
  ],
  "blocks": [
    {
      "type": "size",
      "name": "Taille",
      "settings": [
        { "type": "text", "id": "size", "label": "Taille", "default": "S" },
        { "type": "text", "id": "range", "label": "Plage de poids", "default": "110–152 lb" }
      ]
    }
  ],
  "default": {
    "blocks": [
        { "type": "size", "settings": { "size": "S", "range": "110–152 lb" } },
        { "type": "size", "settings": { "size": "M", "range": "154–196 lb" } },
        { "type": "size", "settings": { "size": "L", "range": "198–240 lb" } },
        { "type": "size", "settings": { "size": "XL", "range": "243–284 lb" } },
        { "type": "size", "settings": { "size": "2XL", "range": "287–328 lb" } },
        { "type": "size", "settings": { "size": "3XL", "range": "331–373 lb" } },
        { "type": "size", "settings": { "size": "4XL", "range": "375–417 lb" } },
        { "type": "size", "settings": { "size": "5XL", "range": "419–463 lb" } }
    ]
  }
}
{% endschema %}

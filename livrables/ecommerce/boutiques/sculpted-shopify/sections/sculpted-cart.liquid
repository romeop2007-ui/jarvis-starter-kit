{%- comment -%}
  Sculpted — Page panier (/cart).
  Corrige la 404 de l'icône caddie (header) ET du logo au checkout : tous deux
  pointent vers routes.cart_url. Sans template cart, Shopify renvoyait une 404.

  Fonctionne SANS JavaScript : le formulaire standard Shopify gère la mise à
  jour des quantités (champ "updates[]" + bouton "update"), la suppression
  (lien item.url_to_remove) et le passage en caisse (bouton "checkout").
  Les remises automatiques (ex : Buy 2 Get 1 Free) sont déjà reflétées dans
  cart.total_price.
{%- endcomment -%}

<section class="cart-page">
  <div class="wrap">
    <h1 class="cart-title display">{{ section.settings.heading | escape }}</h1>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" novalidate class="cart-form">
        <div class="cart-items">
          <div class="cart-head">
            <span>{{ section.settings.col_product | escape }}</span>
            <span class="cart-head__qty">{{ section.settings.col_qty | escape }}</span>
            <span class="cart-head__price">{{ section.settings.col_total | escape }}</span>
          </div>

          {%- comment -%}
            UNE LIGNE PAR ARTICLE RÉEL du panier (article par article, avec sa
            couleur et sa taille). On n'agrège plus et on ne devine plus le
            partage payé/offert : on lit le VRAI prix de chaque ligne.
            item.final_line_price reflète déjà la remise auto "Buy 2 Get 1 Free"
            (Shopify met l'unité offerte à 0) → ce qu'on affiche = ce qu'on paie.
            Le champ caché updates[] (1 par ligne) préserve le panier lors d'un
            "Update" sans JavaScript.
          {%- endcomment -%}
          {%- for item in cart.items -%}
            {%- assign is_free = false -%}
            {%- if item.final_line_price == 0 -%}{%- assign is_free = true -%}{%- endif -%}
            <div class="cart-item{% if is_free %} cart-item--gift{% endif %}">
              <a href="{{ item.url }}" class="cart-item__media frame{% if item.image %} has-img{% endif %}">
                {%- if item.image -%}
                  <img src="{{ item.image | image_url: width: 220 }}" alt="{{ item.title | escape }}" loading="lazy">
                {%- endif -%}
              </a>

              <div class="cart-item__info">
                <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title | escape }}</a>
                {%- if item.variant.title and item.variant.title != 'Default Title' -%}
                  <p class="cart-item__variant">{{ item.variant.title | escape }}</p>
                {%- endif -%}
                {%- for p in item.properties -%}
                  {%- unless p.first contains '_' or p.last == blank -%}
                    <p class="cart-item__prop">{{ p.first | escape }}: {{ p.last | escape }}</p>
                  {%- endunless -%}
                {%- endfor -%}
                <a href="{{ item.url_to_remove }}" class="cart-item__remove">{{ section.settings.remove_label | escape }}</a>
              </div>

              <div class="cart-item__qty">
                {%- if is_free -%}
                  <span class="cart-qty-locked">{{ item.quantity }}</span>
                  <input type="hidden" name="updates[]" value="{{ item.quantity }}">
                {%- else -%}
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" inputmode="numeric" aria-label="Quantity" class="cart-qty-input" data-line="{{ forloop.index }}">
                {%- endif -%}
              </div>

              <div class="cart-item__price">
                {%- if is_free -%}
                  <span class="now cart-price-free">{{ section.settings.free_label | escape }}<span class="cart-gift-badge">{{ section.settings.gift_badge | escape }}</span></span>
                  <span class="was">{{ item.original_line_price | money }}</span>
                {%- else -%}
                  <span class="now">{{ item.final_line_price | money }}</span>
                  {%- if item.original_line_price > item.final_line_price -%}
                    <span class="was">{{ item.original_line_price | money }}</span>
                  {%- endif -%}
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="cart-foot">
          <button type="submit" name="update" class="btn btn-ghost cart-update">{{ section.settings.update_label | escape }}</button>

          <div class="cart-summary">
            {%- if cart.total_discount > 0 -%}
              <p class="cart-discount"><span>{{ section.settings.discount_label | escape }}</span> <b>−{{ cart.total_discount | money }}</b></p>
            {%- endif -%}
            <p class="cart-subtotal"><span>{{ section.settings.subtotal_label | escape }}</span> <b>{{ cart.total_price | money }}</b></p>
            <p class="cart-note">{{ section.settings.shipping_note | escape }}</p>
            <button type="submit" name="checkout" class="btn btn-accent btn-block cart-checkout">{{ section.settings.checkout_label | escape }}</button>
            <a href="{{ section.settings.continue_url | default: routes.root_url }}" class="cart-continue">{{ section.settings.continue_label | escape }}</a>

            {%- comment -%}
              RÉASSURANCE : éléments de confiance ajoutés sous le bouton de paiement,
              au moment de la décision finale. Tout est éditable dans Personnaliser
              et masquable via les cases à cocher. N'affecte ni les prix, ni les
              quantités, ni le passage en caisse.
            {%- endcomment -%}
            {%- if section.settings.show_trust -%}
              <ul class="cart-trust">
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  <span>{{ section.settings.trust_1 | escape }}</span>
                </li>
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V5z"/><path d="M9 12l2 2 4-4"/></svg>
                  <span>{{ section.settings.trust_2 | escape }}</span>
                </li>
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
                  <span>{{ section.settings.trust_3 | escape }}</span>
                </li>
              </ul>
            {%- endif -%}

            {%- if section.settings.show_secure -%}
              <p class="cart-secure">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
                <span>{{ section.settings.secure_text | escape }}</span>
              </p>
            {%- endif -%}

            {%- if section.settings.show_payment -%}
              <div class="cart-pay" aria-label="Accepted payment methods">
                <span class="cart-pay__chip">VISA</span>
                <span class="cart-pay__chip">Mastercard</span>
                <span class="cart-pay__chip">AMEX</span>
                <span class="cart-pay__chip">PayPal</span>
              </div>
            {%- endif -%}
          </div>
        </div>
      </form>

    {%- else -%}
      <div class="cart-empty">
        <p>{{ section.settings.empty_text | escape }}</p>
        <a href="{{ section.settings.continue_url | default: routes.root_url }}" class="btn btn-accent">{{ section.settings.empty_btn | escape }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
/* Réassurance panier (auto-contenu, n'affecte pas le reste du thème). */
.cart-trust{list-style:none;margin:18px 0 0;padding:14px 0 0;border-top:1px solid rgba(0,0,0,.08);display:flex;flex-direction:column;gap:10px}
.cart-trust li{display:flex;align-items:center;gap:10px;font-size:13.5px;line-height:1.3;color:#222}
.cart-trust svg{width:20px;height:20px;flex:0 0 20px;color:#1496d6}
.cart-secure{display:flex;align-items:center;justify-content:center;gap:7px;margin:14px 0 0;font-size:12.5px;font-weight:600;letter-spacing:.02em;color:#3a7d44}
.cart-secure svg{width:15px;height:15px;flex:0 0 15px}
.cart-pay{display:flex;flex-wrap:wrap;justify-content:center;gap:6px;margin:10px 0 0}
.cart-pay__chip{font-size:10.5px;font-weight:700;letter-spacing:.03em;color:#555;background:#f4f5f7;border:1px solid rgba(0,0,0,.07);border-radius:5px;padding:4px 8px}
</style>

<script>
/* Mise à jour live des quantités, ligne par ligne. La quantité saisie est la
   vraie quantité envoyée à Shopify ; la remise auto "Buy 2 Get 1 Free" se
   recalcule toute seule au rechargement (l'article offert repasse à 0 = "Free").
   Sans JavaScript, le bouton "Update cart" fait le même travail via updates[]. */
(function(){
  var inputs = document.querySelectorAll('.cart-qty-input[data-line]');
  if(!inputs.length){ return; }
  inputs.forEach(function(input){
    input.addEventListener('change', function(){
      var line = parseInt(input.getAttribute('data-line'), 10);
      var qty = parseInt(input.value, 10);
      if(isNaN(qty) || qty < 0){ qty = 0; }
      input.disabled = true;
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: line, quantity: qty })
      })
      .then(function(r){ if(!r.ok){ throw new Error('change failed'); } return r.json(); })
      .then(function(){ window.location.reload(); })
      .catch(function(){ input.disabled = false; alert('Could not update quantity. Please try again.'); });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Sculpted — Panier",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "Your cart" },
    { "type": "header", "content": "En-têtes de colonnes" },
    { "type": "text", "id": "col_product", "label": "Colonne produit", "default": "Product" },
    { "type": "text", "id": "col_qty", "label": "Colonne quantité", "default": "Qty" },
    { "type": "text", "id": "col_total", "label": "Colonne total", "default": "Total" },
    { "type": "header", "content": "Libellés" },
    { "type": "text", "id": "remove_label", "label": "Lien supprimer", "default": "Remove" },
    { "type": "text", "id": "gift_badge", "label": "Badge article offert", "default": "Gift" },
    { "type": "text", "id": "free_label", "label": "Libellé prix offert", "default": "Free" },
    { "type": "text", "id": "update_label", "label": "Bouton mettre à jour", "default": "Update cart" },
    { "type": "text", "id": "subtotal_label", "label": "Libellé sous-total", "default": "Subtotal" },
    { "type": "text", "id": "discount_label", "label": "Libellé remise", "default": "Discount" },
    { "type": "text", "id": "shipping_note", "label": "Note livraison/taxes", "default": "Shipping & taxes calculated at checkout." },
    { "type": "text", "id": "checkout_label", "label": "Bouton checkout", "default": "Checkout" },
    { "type": "text", "id": "continue_label", "label": "Lien continuer mes achats", "default": "Continue shopping" },
    { "type": "url", "id": "continue_url", "label": "Lien \"continuer mes achats\"" },
    { "type": "header", "content": "Réassurance (confiance client)" },
    { "type": "checkbox", "id": "show_trust", "label": "Afficher les 3 piliers de confiance", "default": true },
    { "type": "text", "id": "trust_1", "label": "Pilier 1 (livraison)", "default": "Free UK delivery on every order" },
    { "type": "text", "id": "trust_2", "label": "Pilier 2 (garantie)", "default": "30-day money-back guarantee" },
    { "type": "text", "id": "trust_3", "label": "Pilier 3 (paiement)", "default": "Secure & encrypted payment" },
    { "type": "checkbox", "id": "show_secure", "label": "Afficher la ligne \"Secure checkout\"", "default": true },
    { "type": "text", "id": "secure_text", "label": "Texte paiement sécurisé", "default": "Secure checkout — SSL encrypted" },
    { "type": "checkbox", "id": "show_payment", "label": "Afficher les logos de paiement", "default": true },
    { "type": "header", "content": "Panier vide" },
    { "type": "text", "id": "empty_text", "label": "Message panier vide", "default": "Your cart is empty." },
    { "type": "text", "id": "empty_btn", "label": "Bouton panier vide", "default": "Shop now" }
  ],
  "presets": [
    { "name": "Sculpted — Panier" }
  ]
}
{% endschema %}

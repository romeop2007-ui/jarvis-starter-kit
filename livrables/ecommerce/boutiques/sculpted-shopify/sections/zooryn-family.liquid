{%- comment -%}
  ===========================================================================
  Zooryn — Famille de clients / preuve sociale de MARQUE (page d'accueil)
  ---------------------------------------------------------------------------
  Titre "A family of X+", sous-titre, puis un RAIL HORIZONTAL d'avis sur la
  marque (pas sur un produit) : mêmes cartes que les avis produit (★★★★★,
  ✓ Verified, texte, nom + date). Aucune image à fournir.
  Défilement horizontal : swipe au doigt sur mobile, molette verticale -> scroll
  horizontal sur PC (et rend le scroll de page une fois en bout de rail).
  Chaque avis = un bloc "Avis" (texte, nom, date).
  ===========================================================================
{%- endcomment -%}

<section class="zfam">
  <div class="wrap center">
    {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="display zfam-h">{{ section.settings.heading | escape }}</h2>{%- endif -%}
    {%- if section.settings.subtitle != blank -%}<p class="zfam-sub">{{ section.settings.subtitle | escape }}</p>{%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="zfam-track" id="zfam-track-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="rev zfam-rev" {{ block.shopify_attributes }}>
          <div class="top"><span class="stars">★★★★★</span><span class="ver">{{ section.settings.verified_label }}</span></div>
          <p>{{ block.settings.text | escape }}</p>
          <div class="who"><b>{{ block.settings.name | escape }}</b><span>{{ block.settings.date | escape }}</span></div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if section.settings.trust_text != blank -%}
    <p class="zfam-trust center">{{ section.settings.trust_text | escape }}</p>
  {%- endif -%}
</section>

<style>
  .zfam-h{font-size:var(--t-h1)}
  .zfam-sub{color:var(--muted);margin:10px auto 0;max-width:52ch}
  .zfam-track{display:flex;gap:16px;margin-top:40px;padding:4px var(--gutter) 10px;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none}
  .zfam-track::-webkit-scrollbar{display:none}
  .zfam-track .rev{flex:0 0 360px;max-width:85vw;scroll-snap-align:start;text-align:left}
  .zfam-trust{margin-top:30px;color:var(--muted);font-weight:700;font-size:14px;letter-spacing:.04em}
  @media (max-width:749px){
    .zfam-track .rev{flex-basis:80%}
  }
</style>

<script>
/* Rail d'avis marque : sur PC, la molette verticale fait défiler horizontalement.
   On rend le scroll de page une fois arrivé en bout de rail pour ne pas le bloquer. */
(function(){
  var track = document.getElementById('zfam-track-{{ section.id }}');
  if(!track){ return; }
  track.addEventListener('wheel', function(e){
    if(track.scrollWidth <= track.clientWidth){ return; }
    var dy = e.deltaY;
    if(dy === 0){ return; }
    var atStart = track.scrollLeft <= 0;
    var atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 1;
    if((dy < 0 && atStart) || (dy > 0 && atEnd)){ return; }
    e.preventDefault();
    track.scrollLeft += dy;
  }, { passive: false });
})();
</script>


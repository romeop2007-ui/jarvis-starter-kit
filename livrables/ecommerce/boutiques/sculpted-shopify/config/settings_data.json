            "settings": {
              "question": "What if my size doesn't fit?",
              "answer": "We offer free size exchanges within 30 days. Pick by weight using the size guide, and size up if you're at the top of a range."
            }
          },
          "sculpted-faq-4": {
            "type": "item",
            "settings": {
              "question": "Can I machine wash Sculpted™?",
              "answer": "Yes — wash cold on a gentle cycle and hang to dry. Avoid bleach, tumble drying and ironing the compression panels."
            }
          },
          "sculpted-faq-5": {
            "type": "item",
            "settings": {
              "question": "What is Sculpted™ made of?",
              "answer": "A breathable four-way-stretch technical knit (nylon-elastane blend) engineered for firm, comfortable compression that lasts wash after wash."
            }
          },
          "sculpted-faq-6": {
            "type": "item",
            "settings": {
              "question": "Does it show under a white t-shirt?",
              "answer": "No. It's thin and seamless, designed to stay invisible even under a fitted white shirt."
            }
          },
          "sculpted-faq-7": {
            "type": "item",
            "settings": {
              "question": "Is it comfortable or too tight?",
              "answer": "It's firm but breathable — supportive without cutting in. Choosing the right size is key, so follow the weight-based guide."
            }
          },
          "sculpted-faq-8": {
            "type": "item",
            "settings": {
              "question": "Does it really work or is it just marketing?",
              "answer": "The slimming effect is physical and immediate, and it's backed by a 30-day money-back guarantee — so you can judge for yourself risk-free."
            }
          },
          "sculpted-faq-9": {
            "type": "item",
            "settings": {
              "question": "Does it shrink in the wash?",
              "answer": "No, provided you follow the care instructions: cold wash and hang to dry keeps the shape and elasticity intact."
            }
          },
          "sculpted-faq-10": {
            "type": "item",
            "settings": {
              "question": "Why is it more expensive than a normal t-shirt?",
              "answer": "It isn't a normal t-shirt — it's a technical compression garment with engineered shaping zones, premium materials and durable construction built to perform every day."
            }
          }
        },

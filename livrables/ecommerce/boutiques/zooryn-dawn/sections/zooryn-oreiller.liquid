{%- assign verif_svg = '<svg viewBox="0 0 24 24" width="14" height="14"><circle cx="12" cy="12" r="11" fill="currentColor"/><path d="M7 12.3l3.2 3.2L17 8.7" stroke="#F3EFE4" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>' -%}
<section class="reviews" id="avis">
  <div class="wrap">

    <div class="reviews-head reveal">
      <div class="score">
        <span class="stars">★★★★★</span>
        <span class="count"><span class="zore-count-n">{{ rows_p.size }}</span> avis</span>
      </div>
    </div>

    <div class="reviews-tabs reveal" id="zoreTabs">
      <button type="button" class="reviews-tab active" data-tab="produit">Avis produit</button>
      <button type="button" class="reviews-tab" data-tab="boutique">Avis boutique</button>
    </div>

    <div class="reviews-grid" id="zoreReviewsGrid">

      {%- for row in rows_p -%}
        {%- assign f = row | split: "~" -%}
        {%- assign nb = f[1] | plus: 0 -%}
        {%- assign starstr = '' -%}
        {%- for i in (1..5) -%}{%- if i <= nb -%}{%- assign starstr = starstr | append: '★' -%}{%- else -%}{%- assign starstr = starstr | append: '☆' -%}{%- endif -%}{%- endfor -%}
        <article class="review-card reveal" data-tab="produit">
          <div class="review-author">{{ f[0] }} <span class="verified">{{ verif_svg }}Vérifié</span></div>

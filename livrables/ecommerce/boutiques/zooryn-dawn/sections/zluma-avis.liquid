{%- comment -%}
  ZOORYN — Guirlande Luma : avis clients (liste à 1 colonne, sans bouton
  "Écrire un avis" ni icônes filtre/tri, conforme à la page concurrent
  réelle). 36 avis inventés (les 5 du design d'origine + 31 ajoutés),
  prénoms francisés, pagination numérotée 5/page (8 pages, comme le
  concurrent). Note d'honnêteté : avis placeholder à remplacer par de
  vrais avis avant la mise en ligne réelle.
{%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign sid = section.id -%}
{%- assign rows = "Anonyme~4~06/04/2026~Semble bien fonctionner pour l'instant. Curieux de voir comment ça tient en hiver à l'extérieur.~ ||| Marie S.~5~11/04/2026~Vivement recommandé~Je recommande à tous ceux qui ont une terrasse, un balcon ou qui font du camping. Simple, intelligent et élégant. ||| Mickaël F.~5~10/04/2026~Une soirée d'été dans une boîte~J'ai ouvert le colis un vendredi soir. Je l'ai accrochée. J'étais dehors jusqu'à minuit. C'est tout ce qu'il faut savoir. ||| Hélène B.~5~09/04/2026~J'en ai commandé deux d'un coup~J'en ai d'abord commandé une pour tester. Tellement satisfaite que j'en ai commandé deux de plus la même semaine. Une pour la terrasse, une pour le camping. ||| Christophe S.~4~09/04/2026~Le backup USB, c'est malin~Le truc malin c'est qu'elle charge aussi en USB. Les jours vraiment couverts, je la charge vite et elle s'allume automatiquement quand il fait nuit. ||| Léa K.~5~05/04/2026~Installée sur la terrasse en 5 minutes, elle s'allume toute seule à la tombée de la nuit. Magique. ||| Thomas V.~5~04/04/2026~Lumière douce et chaude, parfaite pour les soirées d'été. On l'a clipsée autour du carré potager. ||| Nadia F.~4~03/04/2026~Très jolie guirlande, bonne tenue de charge. Une étoile en moins car le câble est un peu court pour ma terrasse. ||| Romain T.~5~02/04/2026~Tenue toute la nuit sans faiblir, même après une journée nuageuse. Bonne surprise pour un produit solaire. ||| Camille D.~5~01/04/2026~Parfaite pour le camping, légère et facile à accrocher à la tente. On l'utilise à chaque sortie. ||| Julien K.~5~31/03/2026~Rendu très qualitatif, le verre donne un côté chic. Beaucoup de compliments de mes voisins. ||| Sophie R.~4~30/03/2026~Bon produit dans l'ensemble. Le capteur solaire pourrait être un peu plus sensible par temps couvert. ||| Maxime B.~5~29/03/2026~Installée au-dessus du barbecue, ambiance parfaite tous les soirs. Charge complète en une journée de soleil. ||| Élise N.~5~28/03/2026~Très contente, jolie lumière dorée. Facile à fixer avec les crochets fournis. ||| Antoine M.~5~27/03/2026~On l'a accrochée au van, parfaite pour les soirées en bivouac. Tient bien la pluie aussi. ||| Claire V.~5~26/03/2026~Cadeau pour ma mère qui en est ravie. Très simple d'installation, lumière chaleureuse. ||| Damien S.~4~25/03/2026~Bon rapport qualité-prix. J'aurais aimé un fil un peu plus long pour faire le tour de mon balcon. ||| Laura P.~5~24/03/2026~Utilisée toutes les nuits depuis 3 semaines sans aucun souci de charge. Très satisfaite. ||| Florian G.~5~23/03/2026~La luminosité est top, ni trop forte ni trop faible. Parfait pour lire un livre sur la terrasse. ||| Manon C.~5~22/03/2026~Installée autour de la pergola, vraiment joli effet le soir. Allumage automatique très pratique. ||| Quentin L.~5~21/03/2026~Solide et bien fini. On l'a laissée sous la pluie plusieurs fois sans problème. ||| Pauline F.~4~20/03/2026~Bonne guirlande, lumière agréable. Petite déception sur la durée d'allumage en hiver mais logique avec le soleil. ||| Hugo D.~5~19/03/2026~Parfaite pour le camping-car, accrochée à l'auvent elle illumine toute la soirée. ||| Inès B.~5~18/03/2026~Très belle qualité de lumière, on dirait des vraies guirlandes guinguette. Coup de cœur. ||| Vincent A.~5~17/03/2026~Facile à installer, autonomie largement suffisante pour nos soirées d'été. ||| Charlotte M.~5~16/03/2026~On l'utilise pour éclairer l'allée du jardin, ça change vraiment l'ambiance le soir. ||| Yanis K.~4~15/03/2026~Très bon produit, juste un peu sensible aux branchages qui peuvent gêner le capteur solaire selon l'emplacement. ||| Émilie T.~5~14/03/2026~Achetée pour un mariage en extérieur, tout le monde a adoré le rendu lumineux. ||| Baptiste R.~5~13/03/2026~Allumage automatique impeccable, jamais eu à y toucher depuis l'installation. ||| Alicia N.~5~12/03/2026~Belle lumière chaude, parfaite pour habiller la terrasse sans avoir besoin d'électricité. ||| Mathis V.~5~11/03/2026~Utilisée en festival, accrochée à la tente, vraiment pratique et jolie. ||| Sarah L.~4~10/03/2026~Très satisfaite globalement, j'aurais aimé une option pour régler l'intensité lumineuse. ||| Nicolas F.~5~09/03/2026~Tenue impeccable malgré plusieurs orages cet été. Très robuste pour un produit extérieur. ||| Margaux D.~5~08/03/2026~Le rendu est magnifique la nuit, on dirait des lucioles. Mes enfants adorent. ||| Théo P.~5~07/03/2026~Installation simple, autonomie largement suffisante même les jours nuageux. ||| Camille S.~5~06/03/2026~Parfaite pour notre jardin partagé, plusieurs voisins m'ont demandé où je l'avais achetée." | split: " ||| " -%}

<div class="zluma" id="zluma-avis-{{ sid }}">
  <section class="reviews">
    <div class="wrap">

      <div class="reviews-head">
        <div>
          <h2 class="reviews-title">{{ s.heading | default: 'Avis clients' }}</h2>
          <div class="reviews-summary">
            <span class="score">{{ s.score | default: '4,6' }}</span>
            <div>
              {%- assign score_pct = s.score | default: '4,6' | replace: ',', '.' | times: 1.0 | divided_by: 5.0 | times: 100 -%}
              <div class="star-rating"><span class="bg">★★★★★</span><span class="fg" style="width:{{ score_pct }}%;">★★★★★</span></div>
              <div class="count">{{ s.count | default: '36' }} avis</div>
            </div>
          </div>
        </div>
      </div>

      <div class="reviews-sep"></div>

      <div class="reviews-grid" id="zlumaGrid-{{ sid }}">
        {%- for row in rows -%}
          {%- assign f = row | split: "~" -%}
          {%- assign nb = f[1] | plus: 0 -%}
          {%- assign starstr = '' -%}
          {%- for i in (1..5) -%}{%- if i <= nb -%}{%- assign starstr = starstr | append: '★' -%}{%- else -%}{%- assign starstr = starstr | append: '☆' -%}{%- endif -%}{%- endfor -%}
          <div class="review-card">
            <span class="stars">{{ starstr }}</span>
            <div class="meta">
              <div class="avatar">{{ f[0] | slice: 0 }}</div>
              <div class="who"><b>{{ f[0] }}</b>{%- if forloop.first -%}<span class="verif">(Vérifié)</span>{%- endif -%}</div>
              <span class="date">{{ f[2] }}</span>
            </div>
            {%- if f.size == 5 -%}
              <h4>{{ f[3] }}</h4>
              <p>{{ f[4] }}</p>
            {%- else -%}
              <p>{{ f[3] }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      <nav class="reviews-pagination" id="zlumaPager-{{ sid }}" aria-label="Pages d'avis"></nav>

    </div>
  </section>
</div>

<script>
(function(){
  var grid = document.getElementById('zlumaGrid-{{ sid }}');
  var pager = document.getElementById('zlumaPager-{{ sid }}');
  if(!grid || !pager){ return; }
  var PAGE = 5;
  var current = 1;

  function cards(){ return Array.prototype.slice.call(grid.querySelectorAll('.review-card')); }

  function pageList(total, cur){
    if(total <= 6){
      var all = [];
      for(var i = 1; i <= total; i++){ all.push(i); }
      return all;
    }
    if(cur <= 4){ return [1,2,3,4,'...',total]; }
    if(cur >= total - 3){ return [1,'...',total-3,total-2,total-1,total]; }
    return [1,'...',cur-1,cur,cur+1,'...',total];
  }

  function renderPager(total){
    var pages = pageList(total, current);
    var html = '<button type="button" class="page-arrow" data-page="' + (current-1) + '" ' + (current === 1 ? 'disabled' : '') + ' aria-label="Page précédente">&lsaquo;</button>';
    pages.forEach(function(p){
      if(p === '...'){ html += '<span class="page-dots">...</span>'; }
      else { html += '<button type="button" class="page-num' + (p === current ? ' active' : '') + '" data-page="' + p + '">' + p + '</button>'; }
    });
    html += '<button type="button" class="page-arrow" data-page="' + (current+1) + '" ' + (current === total ? 'disabled' : '') + ' aria-label="Page suivante">&rsaquo;</button>';
    pager.innerHTML = html;
    pager.querySelectorAll('button[data-page]').forEach(function(btn){
      btn.addEventListener('click', function(){
        var p = parseInt(btn.getAttribute('data-page'), 10);
        if(p >= 1 && p <= total){ current = p; render(); }
      });
    });
  }

  function render(){
    var list = cards();
    var total = Math.ceil(list.length / PAGE);
    var start = (current - 1) * PAGE;
    var end = start + PAGE;
    list.forEach(function(c, i){ c.style.display = (i >= start && i < end) ? '' : 'none'; });
    renderPager(total);
  }

  render();
})();
</script>

{% schema %}
{
  "name": "Luma — Avis clients",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "Avis clients" },
    { "type": "text", "id": "score", "label": "Note moyenne", "default": "4,6" },
    { "type": "text", "id": "count", "label": "Nombre d'avis", "default": "36" },
    { "type": "text", "id": "more_label", "label": "Bouton voir plus", "default": "Voir plus d’avis" }
  ],
  "presets": [ { "name": "Luma — Avis clients" } ]
}
{% endschema %}

    </div>

    <div class="reviews-more reveal">
      <button type="button" id="zoreMoreReviews">Voir plus d'avis</button>
    </div>
  </div>
</section>

</div>

<script>
(function(){
  var root = document.querySelector('.zore');
  if(!root){ return; }

  /* galerie : carrousel (flèches + vignettes synchronisées), comme la page matelas */
  var mainImg = root.querySelector('#zoreMainImg');
  var mainPh = root.querySelector('#zoreMainPh');
  var thumbsWrap = root.querySelector('#zoreThumbs');
  var thumbs = thumbsWrap ? Array.prototype.slice.call(thumbsWrap.querySelectorAll('.thumb')) : [];
  var prevBtn = root.querySelector('#zorePrev');
  var nextBtn = root.querySelector('#zoreNext');
  var current = 0;

  function showImg(i){
    if(!thumbs.length){ return; }
    if(i < 0){ i = thumbs.length - 1; }
    if(i >= thumbs.length){ i = 0; }
    current = i;
    var t = thumbs[i];
    thumbs.forEach(function(x){ x.classList.remove('active'); });
    t.classList.add('active');
    var url = t.getAttribute('data-img');
    var label = t.getAttribute('data-label') || 'Photo produit';
    if(mainImg && url){ mainImg.src = url; }
    else if(mainPh){ var sp = mainPh.querySelector('span'); if(sp){ sp.textContent = label; } }
    if(thumbsWrap){
      var target = t.offsetLeft - (thumbsWrap.clientWidth / 2) + (t.clientWidth / 2);
      thumbsWrap.scrollTo({ left: target, behavior: 'smooth' });
    }
  }

  thumbs.forEach(function(t, i){ t.addEventListener('click', function(){ showImg(i); }); });
  if(prevBtn){ prevBtn.addEventListener('click', function(){ showImg(current - 1); }); }
  if(nextBtn){ nextBtn.addEventListener('click', function(){ showImg(current + 1); }); }
  if(thumbs.length <= 1){
    if(prevBtn){ prevBtn.style.display = 'none'; }
    if(nextBtn){ nextBtn.style.display = 'none'; }
  }

  /* avis : onglets produit/boutique + pagination 8 par 8 */
  var reviewsGrid = root.querySelector('#zoreReviewsGrid');
  var moreBtn = root.querySelector('#zoreMoreReviews');
  var countEl = root.querySelector('.zore-count-n');
  var PAGE = 8;
  var currentTab = 'produit';
  var shown = PAGE;

  function reviewCards(){ return reviewsGrid ? Array.prototype.slice.call(reviewsGrid.querySelectorAll('.review-card')) : []; }

  function renderReviews(){
    var i = 0, total = 0;
    reviewCards().forEach(function(c){
      if(c.getAttribute('data-tab') === currentTab){
        total++;
        c.style.display = (i < shown) ? '' : 'none';
        i++;
      } else {
        c.style.display = 'none';
      }
    });
    if(countEl){ countEl.textContent = total; }
    if(moreBtn){ moreBtn.style.display = (shown < total) ? '' : 'none'; }
  }

  root.querySelectorAll('.reviews-tab').forEach(function(tab){
    tab.addEventListener('click', function(){
      root.querySelectorAll('.reviews-tab').forEach(function(t){ t.classList.remove('active'); });
      tab.classList.add('active');
      currentTab = tab.getAttribute('data-tab');
      shown = PAGE;
      renderReviews();
    });
  });

  if(moreBtn){ moreBtn.addEventListener('click', function(){ shown += PAGE; renderReviews(); }); }

  renderReviews();

  /* animations au scroll */
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.12 });
  root.querySelectorAll('.reveal').forEach(function(el){ io.observe(el); });
})();
</script>


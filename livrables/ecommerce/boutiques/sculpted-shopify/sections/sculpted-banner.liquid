{%- comment -%}
  Sculpted — Banner image (entre header et hero)
  Upload ton image dans Personnaliser → "Sculpted — Banner image".
  Hauteur, position et lien sont réglables sans toucher au code.
{%- endcomment -%}

{%- assign img   = section.settings.image -%}
{%- assign lnk   = section.settings.link -%}
{%- assign max_h = section.settings.max_height -%}
{%- assign pos   = section.settings.object_position -%}

<div class="sculpted-banner{% unless img %} sculpted-banner--empty{% endunless %}"
     style="--bh:{{ max_h }}px;--bpos:{{ pos }}">
  {%- if lnk != blank -%}<a href="{{ lnk }}" class="sculpted-banner__link">{%- endif -%}

  {%- if img -%}
    <img
      src="{{ img | image_url: width: 1800 }}"
      srcset="{{ img | image_url: width: 600 }} 600w,
              {{ img | image_url: width: 1200 }} 1200w,
              {{ img | image_url: width: 1800 }} 1800w"
      sizes="100vw"
      alt="{{ img.alt | default: 'Sculpted banner' | escape }}"
      loading="eager">
  {%- else -%}
    <span>Upload your banner image in Customise &rarr; "Sculpted &mdash; Banner image"</span>
  {%- endif -%}

  {%- if lnk != blank -%}</a>{%- endif -%}
</div>

{% schema %}
{
  "name": "Sculpted — Banner image",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "number",
      "id": "max_height",
      "label": "Hauteur max (px)",
      "default": 600
    },
    {
      "type": "select",
      "id": "object_position",
      "label": "Cadrage de l'image",
      "options": [
        { "value": "center top",    "label": "Haut" },
        { "value": "center center", "label": "Centre" },
        { "value": "center bottom", "label": "Bas" }
      ],
      "default": "center top"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Lien (optionnel)"
    }
  ],
  "presets": [
    { "name": "Sculpted — Banner image" }
  ]
}
{% endschema %}

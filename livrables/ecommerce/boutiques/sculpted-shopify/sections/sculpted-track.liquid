{%- comment -%}
  Sculpted — Bloc "Track my order" (suivi de commande).
  Champ cosmétique (comme la maquette) : à brancher plus tard sur ton transporteur
  ou une appli de suivi. Tous les textes sont éditables.
{%- endcomment -%}
<section class="track">
  <div class="wrap">
    <h1 class="display">{{ section.settings.heading | escape }}</h1>
    <p class="intro">{{ section.settings.intro | escape }}{% if section.settings.link_label != blank %} <a href="{{ section.settings.link_url | default: '#' }}">{{ section.settings.link_label | escape }}</a>.{% endif %}</p>
    <form class="track-form" onsubmit="return sculptedTrackOrder(event)">
      <input type="text" id="sculptedTrackingNo" placeholder="{{ section.settings.placeholder | escape }}" required />
      <button type="submit" class="btn btn-primary">{{ section.settings.button_label | escape }}</button>
      <p class="track-result" id="sculptedTrackResult">{{ section.settings.not_found | escape }}</p>
    </form>
  </div>
</section>

<script>
/* Suivi cosmétique : affiche le message d'aide. À brancher sur ton suivi réel plus tard. */
function sculptedTrackOrder(e){
  e.preventDefault();
  document.getElementById('sculptedTrackResult').classList.add('show');
  return false;
}
</script>

{% schema %}
{
  "name": "Sculpted — Track order",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "Track my order" },
    { "type": "textarea", "id": "intro", "label": "Texte d'intro", "default": "Enter the tracking number from the shipping confirmation email you received. Need help tracking your order?" },
    { "type": "text", "id": "link_label", "label": "Lien — libellé", "default": "Get in touch via our contact form" },
    { "type": "url", "id": "link_url", "label": "Lien — URL" },
    { "type": "text", "id": "placeholder", "label": "Placeholder du champ", "default": "Tracking number" },
    { "type": "text", "id": "button_label", "label": "Bouton", "default": "Track" },
    { "type": "textarea", "id": "not_found", "label": "Message si non trouvé", "default": "We couldn't find that tracking number yet. Newly shipped orders can take up to 24 hours to appear — please try again shortly." }
  ]
}
{% endschema %}

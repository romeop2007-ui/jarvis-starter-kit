{%- comment -%}
  Defyne — Avis clients (mur d'avis). Chaque avis est un bloc (texte, nom, date).
  Étoiles fixes à 5 et libellé "Verified" commun, comme la maquette.
{%- endcomment -%}
<section class="reviews">
  <div class="wrap">
    <p class="eyebrow center">{{ section.settings.eyebrow | escape }}</p>
    <h2 class="display">{{ section.settings.heading | escape }}</h2>
    <div class="rev-grid">
      {%- for block in section.blocks -%}
        <div class="rev" {{ block.shopify_attributes }}>
          <div class="top"><span class="stars">★★★★★</span><span class="ver">{{ section.settings.verified_label }}</span></div>
          <p>{{ block.settings.text | escape }}</p>
          <div class="who"><b>{{ block.settings.name | escape }}</b><span>{{ block.settings.date | escape }}</span></div>
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.more_label != blank -%}
      <div class="rev-more"><a href="{{ section.settings.more_url | default: '#' }}" class="btn btn-ghost">{{ section.settings.more_label | escape }}</a></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Defyne — Avis",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Customer reviews" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "What they say about Defyne™" },
    { "type": "text", "id": "verified_label", "label": "Libellé vérifié", "default": "✓ Verified" },
    { "type": "text", "id": "more_label", "label": "Bouton — texte", "default": "Load more reviews →" },
    { "type": "url", "id": "more_url", "label": "Bouton — lien" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Avis",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Avis", "default": "Got it yesterday, wore it today at the office. Impressive." },
        { "type": "text", "id": "name", "label": "Nom", "default": "Arnaud L." },
        { "type": "text", "id": "date", "label": "Date", "default": "2 days ago" }
      ]
    }
  ],
  "default": {
    "blocks": [
        { "type": "review", "settings": { "text": "Got it yesterday, wore it today at the office. My boss asked if I'd changed my haircut. Nope — just Defyne under my shirt. Impressive.", "name": "Arnaud L.", "date": "2 days ago" } },
        { "type": "review", "settings": { "text": "After my post-lockdown weight gain I avoided mirrors. First morning with Defyne I looked in the mirror and smiled. It had been a while.", "name": "Bertrand C.", "date": "1 week ago" } },
        { "type": "review", "settings": { "text": "I'm skeptical by nature but I'm blown away. My stomach looks flat, my posture is better and I genuinely feel good. Ordered 2 more.", "name": "Romain L.", "date": "3 weeks ago" } },
        { "type": "review", "settings": { "text": "I'm a restaurant waiter, on my feet 8h a day. Defyne holds perfectly, nothing rides up, and my posture has really improved.", "name": "Enzo R.", "date": "4 days ago" } },
        { "type": "review", "settings": { "text": "I'm a sales rep and see clients all day. Image matters. Defyne gave me back the confidence I'd lost.", "name": "Samy B.", "date": "10 days ago" } },
        { "type": "review", "settings": { "text": "My girlfriend gave me Defyne for my birthday. At first I wasn't convinced. Now she has to force me to take it off to wash it.", "name": "Kevin T.", "date": "3 weeks ago" } },
        { "type": "review", "settings": { "text": "I was afraid it'd feel like a girdle. Not at all. It's discreet and genuinely improves your stature. I stand straight now.", "name": "Tarek M.", "date": "6 days ago" } },
        { "type": "review", "settings": { "text": "In sales, on my feet all day. Defyne holds perfectly, nothing rides up, and it's invisible under a white shirt. Perfect.", "name": "Julien M.", "date": "2 weeks ago" } }
    ]
  }
}
{% endschema %}

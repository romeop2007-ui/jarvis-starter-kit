{%- comment -%}
  Sculpted — Header / menu de navigation. Chrome partagé via le layout.
  Le bandeau ticker (messages défilants) est désormais intégré EN HAUT du header,
  pour former un seul bloc compact (plus de zone vide entre ticker et nav).
  - Bandeau ticker : blocs "Message" (défilent en boucle).
  - Logo : 2 parties (texte normal + texte accentué en bleu), éditables.
  - Liens de nav : blocs "Lien de menu" (libellé + URL). Le lien de la page
    courante se met en surbrillance automatiquement.
  - Côté droit : uniquement l'icône panier (sac bleu) → page /cart.
{%- endcomment -%}
<header>
  {%- assign ticker_blocks = section.blocks | where: 'type', 'message' -%}
  {%- if ticker_blocks.size > 0 -%}
    <div class="ticker header-ticker">
      <div class="ticker-track">
        {%- for block in ticker_blocks -%}
          <span {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</span>
        {%- endfor -%}
        {%- comment -%} Deuxième passe identique : assure une boucle fluide {%- endcomment -%}
        {%- for block in ticker_blocks -%}
          <span aria-hidden="true">{{ block.settings.text | escape }}</span>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
  <div class="wrap nav">
    {%- comment -%} Bouton hamburger (téléphone uniquement, masqué sur PC via le CSS) {%- endcomment -%}
    <input type="checkbox" id="sc-menu-toggle" class="sc-menu-toggle">
    <label for="sc-menu-toggle" class="sc-burger" aria-label="Ouvrir le menu">
      <span></span><span></span><span></span>
    </label>
    <a href="{{ routes.root_url }}" class="logo">{{ section.settings.logo_text }}<b>{{ section.settings.logo_accent }}</b></a>
    <nav class="nav-links">
      {%- for block in section.blocks -%}
        {%- if block.type != 'link' -%}{%- continue -%}{%- endif -%}
        {%- assign is_active = false -%}
        {%- if block.settings.url != blank and block.settings.url == request.path -%}{%- assign is_active = true -%}{%- endif -%}
        <a href="{{ block.settings.url | default: '#' }}"{% if is_active %} class="active"{% endif %} {{ block.shopify_attributes }}>{{ block.settings.label | escape }}</a>
      {%- endfor -%}
    </nav>
    <div class="nav-utils">
      <a href="{{ routes.cart_url }}" class="cart-link" aria-label="Cart">
        <svg class="icon cart-bag" viewBox="0 0 24 24"><path d="M5.5 8h13l-1 11.4a1 1 0 0 1-1 .9H7.5a1 1 0 0 1-1-.9L5.5 8z"/><path d="M8.5 8V6.5a3.5 3.5 0 0 1 7 0V8"/></svg>
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Sculpted — Header",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo — début", "default": "De" },
    { "type": "text", "id": "logo_accent", "label": "Logo — partie bleue", "default": "fyne" }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message ticker",
      "settings": [
        { "type": "text", "id": "text", "label": "Texte du message", "default": "Free shipping until midnight tonight" }
      ]
    },
    {
      "type": "link",
      "name": "Lien de menu",
      "settings": [
        { "type": "text", "id": "label", "label": "Libellé", "default": "Home" },
        { "type": "url", "id": "url", "label": "Lien" }
      ]
    }
  ],
  "default": {
    "blocks": [
        { "type": "message", "settings": { "text": "In stock — selling out fast" } },
        { "type": "message", "settings": { "text": "Limited-time sale" } },
        { "type": "message", "settings": { "text": "Free shipping until midnight tonight" } },
        { "type": "link", "settings": { "label": "Home" } },
        { "type": "link", "settings": { "label": "Sculpted" } },
        { "type": "link", "settings": { "label": "Contact" } },
        { "type": "link", "settings": { "label": "Track my order" } }
    ]
  }
}
{% endschema %}

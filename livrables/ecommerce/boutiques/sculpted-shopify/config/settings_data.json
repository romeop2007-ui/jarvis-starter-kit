          "sculpted-reviews-0": { "type": "review", "settings": { "text": "Got it yesterday, wore it today at the office. My boss asked if I'd changed my haircut. Nope — just Sculpted under my shirt. Impressive.", "name": "Arnaud L.", "date": "2 days ago" } },
          "sculpted-reviews-1": { "type": "review", "settings": { "text": "After my post-lockdown weight gain I avoided mirrors. First morning with Sculpted I looked in the mirror and smiled. It had been a while.", "name": "Bertrand C.", "date": "1 week ago" } },
          "sculpted-reviews-2": { "type": "review", "settings": { "text": "I'm skeptical by nature but I'm blown away. My stomach looks flat, my posture is better and I genuinely feel good. Ordered 2 more.", "name": "Romain L.", "date": "3 weeks ago" } },
          "sculpted-reviews-3": { "type": "review", "settings": { "text": "I'm a restaurant waiter, on my feet 8h a day. Sculpted holds perfectly, nothing rides up, and my posture has really improved.", "name": "Enzo R.", "date": "4 days ago" } },
          "sculpted-reviews-4": { "type": "review", "settings": { "text": "I'm a sales rep and see clients all day. Image matters. Sculpted gave me back the confidence I'd lost.", "name": "Samy B.", "date": "10 days ago" } },
          "sculpted-reviews-5": { "type": "review", "settings": { "text": "My girlfriend gave me Sculpted for my birthday. At first I wasn't convinced. Now she has to force me to take it off to wash it.", "name": "Kevin T.", "date": "3 weeks ago" } },
          "sculpted-reviews-6": { "type": "review", "settings": { "text": "I was afraid it'd feel like a girdle. Not at all. It's discreet and genuinely improves your stature. I stand straight now.", "name": "Tarek M.", "date": "6 days ago" } },
          "sculpted-reviews-7": { "type": "review", "settings": { "text": "In sales, on my feet all day. Sculpted holds perfectly, nothing rides up, and it's invisible under a white shirt. Perfect.", "name": "Julien M.", "date": "2 weeks ago" } }

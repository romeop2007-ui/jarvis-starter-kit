{% layout 'defyne' %}
{%- comment -%}
  ===========================================================================
  Defyne — Template de page d'accueil (rendu 1:1 de "Defyne Homepage.html")
  ---------------------------------------------------------------------------
  Reproduction EXACTE de la maquette Claude Design : ticker, header/nav, hero,
  press bar, benefits, social proof, buy box (tiers de prix, options, UGC,
  accordéons), how it works, stats, comparatif, size guide, FAQ, reviews,
  badges, footer. CSS et markup identiques à la maquette.

  Seules adaptations : les liens de nav/footer pointent vers des URL Shopify.
  Les visuels sont des cadres placeholder (.frame) comme dans la maquette :
  à remplacer par les vraies photos produit plus tard.

  Utilise le layout isolé 'defyne' → ne dépend PAS du thème Dawn.
  (Sur le thème preview, templates/index.json a été supprimé au profit de ce fichier.)
  ===========================================================================
{%- endcomment -%}

<style>
/* ---------- 1. TOKENS ------------------------------------------------ */
:root{
  --ink:#101114; --paper:#ffffff; --soft:#f4f5f7; --muted:#73777e;
  --line:#e6e8eb; --accent:#1496d6; --accent-deep:#0c79b3; --ok:#1f9d57; --warn:#d2473c;
  --maxw:1180px; --gutter:24px; --r:14px;
  --t-hero:clamp(38px, 6vw, 84px); --t-h1:clamp(30px, 4.4vw, 56px);
  --t-h2:clamp(24px, 3vw, 40px); --t-h3:22px; --t-body:17px; --t-small:14px; --t-eyebrow:13px;
}
/* ---------- 2. RESET / BASE ------------------------------------------ */
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Archivo',system-ui,sans-serif;color:var(--ink);background:var(--paper);
  font-size:var(--t-body);line-height:1.55;-webkit-font-smoothing:antialiased;}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer;border:none;background:none}
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 var(--gutter)}
section{padding:96px 0}
.tint{background:var(--soft)}
.eyebrow{font-size:var(--t-eyebrow);font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);margin-bottom:18px;}
.display{font-weight:900;line-height:1.02;letter-spacing:-.01em;text-transform:uppercase;}
.accent{color:var(--accent)}
.center{text-align:center}
/* ---------- 3. IMAGE PLACEHOLDER FRAME ------------------------------- */
.frame{position:relative;background:repeating-linear-gradient(135deg,#eceef1 0 14px,#f3f5f7 14px 28px);
  border:1px solid var(--line);border-radius:var(--r);display:flex;align-items:center;justify-content:center;
  text-align:center;color:var(--muted);min-height:120px;overflow:hidden;}
.frame span{font-size:11px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;padding:8px 14px;}
.frame.dark{background:repeating-linear-gradient(135deg,#1a1c20 0 14px,#212429 14px 28px);border-color:#2a2d33;color:#8b9099;}
/* ---------- 4. BUTTONS ----------------------------------------------- */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;font-weight:700;font-size:var(--t-small);
  letter-spacing:.08em;text-transform:uppercase;padding:18px 34px;border-radius:999px;transition:transform .15s ease, background .15s ease;}
.btn:active{transform:translateY(1px)}
.btn-primary{background:var(--ink);color:#fff}
.btn-primary:hover{background:#000}
.btn-accent{background:var(--accent);color:#fff}
.btn-accent:hover{background:var(--accent-deep)}
.btn-ghost{border:1px solid var(--ink);color:var(--ink)}
.btn-ghost:hover{background:var(--ink);color:#fff}
.btn-block{width:100%}
/* ---------- 5. ANNOUNCEMENT TICKER ----------------------------------- */
.ticker{background:var(--ink);color:#fff;overflow:hidden;white-space:nowrap}
.ticker-track{display:inline-flex;gap:0;padding:10px 0;animation:scroll 28s linear infinite;}
.ticker-track span{font-size:12px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;padding:0 36px;position:relative;}
.ticker-track span::after{content:"•";position:absolute;right:-4px;opacity:.45}
@keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
/* ---------- 6. HEADER ------------------------------------------------ */
header{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.92);backdrop-filter:blur(10px);border-bottom:1px solid var(--line);}
.nav{display:flex;align-items:center;justify-content:space-between;height:74px}
.logo{font-weight:900;font-size:22px;letter-spacing:.04em;text-transform:uppercase}
.logo b{color:var(--accent)}
.nav-links{display:flex;gap:34px}
.nav-links a{font-weight:600;font-size:15px;color:var(--ink);position:relative}
.nav-links a:hover{color:var(--accent)}
.nav-utils{display:flex;align-items:center;gap:22px;color:var(--ink)}
.nav-utils .cur{font-weight:600;font-size:14px;display:flex;align-items:center;gap:6px}
.icon{width:21px;height:21px;stroke:currentColor;fill:none;stroke-width:1.7}
/* ---------- 7. HERO -------------------------------------------------- */
.hero{position:relative;padding:0}
.hero-frame{min-height:88vh;border-radius:0;border:none;border-bottom:1px solid var(--line);flex-direction:column;gap:40px;
  background:radial-gradient(120% 90% at 50% 0%,#fafbfc 0%,#eceef1 60%,#e3e6ea 100%);}
.hero-inner{display:flex;flex-direction:column;align-items:center;gap:30px;padding:80px 24px;max-width:1000px}
.hero h1{font-size:var(--t-hero);max-width:14ch}
.hero h1 .pill{display:inline-block;background:var(--accent);color:#fff;padding:.04em .35em;border-radius:10px;margin-top:.12em;}
.trust{display:flex;align-items:center;gap:14px;flex-wrap:wrap;justify-content:center}
.stars{color:#00b67a;font-size:22px;letter-spacing:2px}
.trust b{font-weight:800}
.hero-feats{display:grid;grid-template-columns:repeat(3,1fr);gap:30px;max-width:760px;width:100%;margin-top:6px;}
.feat{display:flex;flex-direction:column;align-items:center;gap:12px;text-align:center}
.feat .ic{width:40px;height:40px;stroke:var(--ink);fill:none;stroke-width:1.6}
.feat p{font-weight:700;font-size:14px;letter-spacing:.04em;text-transform:uppercase;line-height:1.3}
/* ---------- 8. PRESS BAR --------------------------------------------- */
.press{padding:46px 0;border-bottom:1px solid var(--line)}
.press .eyebrow{text-align:center;color:var(--muted)}
.press-logos{display:flex;align-items:center;justify-content:center;gap:clamp(28px,6vw,72px);flex-wrap:wrap;}
.press-logos span{font-weight:800;font-size:24px;letter-spacing:.04em;color:#2a2d33;opacity:.8}
/* ---------- 9. BENEFITS SPLIT ---------------------------------------- */
.benefits .lead{max-width:18ch;margin:0 auto 70px;font-size:var(--t-h1)}
.benefits-grid{display:grid;grid-template-columns:1fr 1.05fr 1fr;gap:48px;align-items:center;}
.benefit{display:flex;flex-direction:column;align-items:center;gap:18px;text-align:center}
.benefit .ic{width:54px;height:54px;stroke:var(--ink);fill:none;stroke-width:1.5}
.benefit h3{font-size:var(--t-h3);font-weight:900;text-transform:uppercase;line-height:1.15}
.benefit-col{display:flex;flex-direction:column;gap:64px}
.benefits-grid .frame{aspect-ratio:3/4;align-self:stretch}
/* ---------- 10. SOCIAL PROOF / TESTIMONIALS -------------------------- */
.proof .lead{font-size:var(--t-h2);font-weight:800;max-width:22ch;margin:0 auto 22px}
.proof-trust{display:flex;flex-direction:column;align-items:center;gap:6px;margin-bottom:56px}
.proof-trust a{font-weight:700;text-decoration:underline;text-underline-offset:3px}
.tcards{display:grid;grid-template-columns:repeat(3,1fr);gap:30px}
.tcard{display:flex;flex-direction:column;gap:16px}
.tcard .frame{aspect-ratio:4/5}
.tcard .name{font-size:19px;font-weight:700;text-align:center}
.tcard blockquote{color:var(--muted);font-size:15px;line-height:1.6;text-align:center}
/* ---------- 11. PRODUCT / BUY BOX ------------------------------------ */
.buy-grid{display:grid;grid-template-columns:1.05fr 1fr;gap:56px;align-items:start}
.gallery{display:grid;grid-template-columns:64px 1fr;gap:16px}
.thumbs{display:flex;flex-direction:column;gap:12px}
.thumbs .frame{aspect-ratio:1;min-height:0;border-radius:10px}
.gallery .hero-img{aspect-ratio:1;min-height:0}
.buy-info .rating{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--muted);font-weight:600}
.buy-info .rating .stars{font-size:15px}
.buy-info h2{font-size:28px;font-weight:800;margin:14px 0 12px;line-height:1.15}
.buy-info .desc{color:var(--muted);font-size:15px;margin-bottom:24px}
.bullets{display:grid;grid-template-columns:1fr 1fr;gap:14px 24px;padding:22px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
.bullet{display:flex;align-items:center;gap:10px;font-size:14px;font-weight:600}
.bullet .ic{width:22px;height:22px;stroke:var(--accent);fill:none;stroke-width:1.6;flex:none}
.stock{display:inline-block;margin:20px 0 8px;background:#fdeceb;color:var(--warn);font-weight:700;font-size:13px;padding:7px 14px;border-radius:8px}
.size-link{display:flex;align-items:center;gap:8px;font-weight:700;font-size:14px;text-decoration:underline;text-underline-offset:3px;margin-bottom:26px}
.promo-label{font-weight:800;font-size:13px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);text-align:center;margin-bottom:16px}
.tier{position:relative;display:flex;align-items:center;gap:16px;border:1.5px solid var(--line);border-radius:12px;padding:18px 20px;margin-bottom:14px;cursor:pointer;transition:border-color .15s}
.tier:hover{border-color:var(--ink)}
.tier.sel{border-color:var(--accent);box-shadow:0 0 0 3px rgba(20,150,214,.12)}
.tier .pack{font-size:13px;font-weight:800;color:var(--muted);width:34px}
.tier .label{font-weight:800;font-size:17px;flex:1}
.tier .ship{font-size:11px;font-weight:700;color:var(--accent-deep);background:rgba(20,150,214,.1);padding:4px 9px;border-radius:6px;margin-left:8px}
.tier .price{text-align:right}
.tier .price .now{font-weight:800;font-size:18px}
.tier .price .was{font-size:13px;color:var(--muted);text-decoration:line-through}
.tier .flag{position:absolute;top:-11px;right:16px;font-size:10px;font-weight:800;letter-spacing:.06em;text-transform:uppercase;color:#fff;background:var(--ink);padding:4px 10px;border-radius:6px}
.tier .flag.hot{background:var(--warn)}
.tier-opts{display:none;gap:10px;margin-top:14px;padding-top:14px;border-top:1px dashed var(--line)}
.tier.sel .tier-opts{display:flex;flex-direction:column}
.opt-row{display:flex;align-items:center;gap:10px;font-size:13px}
.opt-row .n{width:24px;font-weight:700;color:var(--muted)}
.opt-row select{flex:1;padding:9px 12px;border:1px solid var(--line);border-radius:8px;font-family:inherit;font-size:13px;background:#fff}
.last-chance{text-align:center;margin:34px 0 14px}
.last-chance h3{font-size:26px;font-weight:900;text-transform:uppercase;margin-bottom:18px}
.lc-eq{display:flex;align-items:center;justify-content:center;gap:18px;margin-bottom:14px}
.lc-eq .frame{width:96px;aspect-ratio:3/4;min-height:0}
.lc-eq .op{font-size:30px;font-weight:900;color:var(--accent)}
.lc-line{font-weight:900;font-size:18px;text-transform:uppercase}
.lc-line em{color:var(--ok);font-style:normal}
.lc-badges{display:flex;justify-content:center;gap:10px;margin:14px 0 18px;flex-wrap:wrap}
.lc-badges span{font-size:11px;font-weight:700;padding:6px 12px;border-radius:8px}
.lc-badges .a{background:#e9f7ef;color:var(--ok)}
.lc-badges .b{background:#fdeceb;color:var(--warn)}
.pay-row{display:flex;justify-content:center;gap:14px;flex-wrap:wrap;margin-top:22px}
.pay-row span{font-size:11px;font-weight:700;letter-spacing:.05em;color:var(--muted);border:1px solid var(--line);border-radius:6px;padding:7px 11px}
.ugc{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:30px}
.ugc .frame{aspect-ratio:9/14}
.ugc .play{position:absolute;bottom:14px;left:14px;width:38px;height:38px;border-radius:50%;background:rgba(255,255,255,.9);display:flex;align-items:center;justify-content:center}
.ugc .play svg{width:16px;height:16px;fill:var(--ink)}
.acc{border-top:1px solid var(--line)}
details.row{border-bottom:1px solid var(--line)}
details.row summary{list-style:none;display:flex;align-items:center;justify-content:space-between;padding:20px 2px;font-weight:700;font-size:16px;cursor:pointer;}
details.row summary::-webkit-details-marker{display:none}
details.row summary .pm{font-size:24px;font-weight:400;transition:transform .2s;color:var(--muted)}
details.row[open] summary .pm{transform:rotate(45deg)}
details.row .body{padding:0 2px 22px;color:var(--muted);font-size:15px;max-width:62ch}
/* ---------- 12. HOW IT WORKS ----------------------------------------- */
.how .display{font-size:var(--t-h2);margin-bottom:64px}
.how-grid{display:grid;grid-template-columns:1fr 1.1fr 1fr;gap:40px;align-items:center}
.how-frame{aspect-ratio:3/4;min-height:0}
.how-note{display:flex;flex-direction:column;gap:8px;padding:24px 0}
.how-col.right{text-align:left}
.how-col.left{text-align:right}
.how-note .tag{display:flex;align-items:center;gap:12px;font-weight:800;font-size:17px}
.how-col.left .tag{flex-direction:row-reverse}
.how-note .dot{width:34px;height:34px;border-radius:50%;background:#eef6fb;display:flex;align-items:center;justify-content:center;flex:none}
.how-note .dot svg{width:18px;height:18px;stroke:var(--accent);fill:none;stroke-width:1.7}
.how-note p{color:var(--muted);font-size:14px}
/* ---------- 13. TRANSFORMATION STATS --------------------------------- */
.transform-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.transform h2{font-size:var(--t-h1);margin-bottom:44px;line-height:1.05}
.stat{margin-bottom:34px}
.stat .k{font-size:13px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:6px}
.stat .v{font-size:clamp(46px,6vw,72px);font-weight:900;line-height:1;margin-bottom:14px}
.bar{height:8px;background:var(--line);border-radius:99px;overflow:hidden;margin-bottom:14px}
.bar i{display:block;height:100%;background:var(--accent);border-radius:99px}
.stat p{color:var(--muted);font-size:15px;max-width:46ch}
.footnote{font-size:12px;color:var(--muted);font-style:italic;margin-top:10px}
.ba{display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--line);border-radius:var(--r);overflow:hidden}
.ba .col{display:flex;flex-direction:column}
.ba .frame{border:none;border-radius:0;aspect-ratio:3/4;min-height:0}
.ba .tagtop{position:absolute;top:14px;left:14px;background:#fff;border-radius:99px;font-size:11px;font-weight:800;letter-spacing:.06em;padding:6px 12px}
.ba .col:last-child .tagtop{left:auto;right:14px}
.ba .cap{padding:16px;text-align:center;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);background:#fff;border-top:1px solid var(--line)}
/* ---------- 14. COMPARISON TABLE ------------------------------------- */
.why .display{font-size:var(--t-h2);margin-bottom:50px}
.compare{width:100%;border-collapse:collapse;max-width:920px;margin:0 auto;border:1px solid var(--line);border-radius:var(--r);overflow:hidden}
.compare th,.compare td{padding:18px 20px;text-align:center;border-bottom:1px solid var(--line)}
.compare th:first-child,.compare td:first-child{text-align:left;font-weight:600;font-size:15px}
.compare thead th{vertical-align:bottom}
.compare .colhead{font-size:11px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
.compare .colhead.brand{color:var(--accent)}
.compare .ch-frame{width:74px;aspect-ratio:3/4;margin:0 auto 10px;min-height:0}
.compare tbody tr:nth-child(odd){background:var(--soft)}
.compare .yes{color:var(--ok);font-weight:900;font-size:18px}
.compare .no{color:#c7cbd1;font-weight:900;font-size:18px}
.compare .brandcol{background:rgba(20,150,214,.05)}
/* ---------- 15. SIZE GUIDE ------------------------------------------- */
.size-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center}
.size h2{font-size:var(--t-h1);margin-bottom:30px}
.size-table{width:100%;border-collapse:collapse}
.size-table td{padding:15px 18px;border-bottom:1px solid var(--line);font-size:18px}
.size-table tr:last-child td{border-bottom:none}
.size-table td:first-child{font-weight:800;width:90px}
.size-table td:last-child{color:var(--muted)}
.size .tip{margin-top:20px;font-style:italic;color:var(--muted);font-size:14px}
.size .frame{aspect-ratio:3/4;min-height:0}
/* ---------- 16. FAQ -------------------------------------------------- */
.faq-head{text-align:center;margin-bottom:50px}
.faq-head h2{font-size:var(--t-h2);font-weight:800;max-width:22ch;margin:0 auto}
.faq-list{max-width:820px;margin:0 auto}
/* ---------- 17. REVIEWS ---------------------------------------------- */
.reviews .display{font-size:var(--t-h2);text-align:center;margin-bottom:46px}
.rev-grid{columns:3;column-gap:24px}
.rev{break-inside:avoid;border:1px solid var(--line);border-radius:12px;padding:22px;margin-bottom:24px}
.rev .top{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.rev .top .stars{font-size:14px;color:#ffb400}
.rev .ver{font-size:12px;font-weight:700;color:var(--ok)}
.rev p{font-size:14px;line-height:1.6;color:#3a3d42;margin-bottom:16px}
.rev .who{display:flex;justify-content:space-between;align-items:center}
.rev .who b{font-size:14px}
.rev .who span{font-size:12px;color:var(--muted)}
.rev-more{text-align:center;margin-top:14px}
.tb-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:30px;margin-top:90px}
.tb{display:flex;flex-direction:column;align-items:center;gap:16px;text-align:center}
.tb .circ{width:74px;height:74px;border-radius:50%;background:#dbe7ee;display:flex;align-items:center;justify-content:center}
.tb:first-child .circ{background:var(--ink)}
.tb:first-child .circ svg{stroke:#fff}
.tb .circ svg{width:30px;height:30px;stroke:#4a5560;fill:none;stroke-width:1.6}
.tb p{font-weight:700;font-size:15px;max-width:16ch}
/* ---------- 18. FOOTER ----------------------------------------------- */
footer{background:var(--ink);color:#fff;padding:80px 0 40px}
.foot-top{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:48px;margin-bottom:64px}
.foot-news h3{font-size:30px;font-weight:700;line-height:1.15;margin-bottom:24px;max-width:14ch}
.news-input{display:flex;border:1px solid #34373d;border-radius:10px;overflow:hidden;max-width:420px}
.news-input input{flex:1;background:transparent;border:none;color:#fff;padding:16px 18px;font-family:inherit;font-size:15px;outline:none}
.news-input input::placeholder{color:#7c8088}
.news-input button{padding:0 20px;color:#fff;font-size:18px}
.foot-col h4{font-size:13px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:#8b9099;margin-bottom:20px}
.foot-col a{display:block;color:#d4d6da;font-size:15px;padding:7px 0}
.foot-col a:hover{color:#fff}
.foot-bot{display:flex;justify-content:space-between;align-items:center;border-top:1px solid #2a2d33;padding-top:30px;flex-wrap:wrap;gap:20px}
.foot-bot .cur{display:flex;align-items:center;gap:8px;font-weight:600;font-size:14px}
.foot-bot .cp{font-size:13px;color:#8b9099}
.foot-pay{display:flex;gap:8px;flex-wrap:wrap}
.foot-pay span{font-size:10px;font-weight:700;color:#9ba0a7;border:1px solid #34373d;border-radius:5px;padding:5px 8px}
/* ---------- 19. RESPONSIVE ------------------------------------------- */
@media (max-width:980px){
  .nav-links{display:none}
  .benefits-grid{grid-template-columns:1fr;gap:48px}
  .benefit-col{flex-direction:row;justify-content:center;flex-wrap:wrap;gap:48px}
  .buy-grid,.transform-grid,.size-grid,.how-grid{grid-template-columns:1fr;gap:40px}
  .how-col.left{text-align:left}.how-col.left .tag{flex-direction:row}
  .tcards{grid-template-columns:1fr}
  .rev-grid{columns:1}
  .foot-top{grid-template-columns:1fr;gap:36px}
  .tb-grid{grid-template-columns:1fr 1fr;gap:40px}
  .hero-feats{grid-template-columns:1fr;gap:24px}
}
@media (max-width:560px){
  section{padding:64px 0}
  .bullets{grid-template-columns:1fr}
  .ugc{grid-template-columns:1fr 1fr}
  .compare{font-size:13px}
  .compare th,.compare td{padding:12px 8px}
}
</style>

<!-- ============ ANNOUNCEMENT TICKER ============ -->
<div class="ticker">
  <div class="ticker-track">
    <span>In stock — selling out fast</span>
    <span>Limited-time sale</span>
    <span>Free shipping until midnight tonight</span>
    <span>In stock — selling out fast</span>
    <span>Limited-time sale</span>
    <span>Free shipping until midnight tonight</span>
  </div>
</div>

<!-- ============ HEADER ============ -->
<header>
  <div class="wrap nav">
    <a href="{{ routes.root_url }}" class="logo">De<b>fyne</b></a>
    <nav class="nav-links">
      <a href="{{ routes.root_url }}">Home</a>
      <a href="#product">Defyne</a>
      <a href="/pages/contact">Contact</a>
      <a href="/pages/track-order">Track my order</a>
    </nav>

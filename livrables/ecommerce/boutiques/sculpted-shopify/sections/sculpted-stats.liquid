{%- comment -%}
  Sculpted — Stats de transformation + avant/après.
  Chaque stat est un bloc (libellé, valeur, % de barre, texte).
{%- endcomment -%}
<section class="transform">
  <div class="wrap">
    <div class="transform-grid">
      <div>
        <h2 class="display">{{ section.settings.heading | escape }} <span class="accent">{{ section.settings.heading_accent | escape }}</span></h2>
        {%- for block in section.blocks -%}
          <div class="stat" {{ block.shopify_attributes }}>
            <div class="k">{{ block.settings.k | escape }}</div><div class="v">{{ block.settings.v | escape }}</div>
            <div class="bar"><i style="width:{{ block.settings.bar }}%"></i></div>
            <p>{{ block.settings.text | escape }}</p>
          </div>
        {%- endfor -%}
        {%- if section.settings.footnote != blank -%}<p class="footnote">{{ section.settings.footnote | escape }}</p>{%- endif -%}
      </div>
      <div class="frame size-single{% if section.settings.image != blank %} has-img{% endif %}">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1254 }}" alt="" width="1254" height="1254" loading="lazy">
        {%- else -%}
          <span>1254 × 1254</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sculpted — Stats",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "A real transformation" },
    { "type": "text", "id": "heading_accent", "label": "Titre — partie bleue", "default": "in 30 days" },
    { "type": "textarea", "id": "footnote", "label": "Note de bas", "default": "*Based on a post-purchase survey of 2,000+ Sculpted™ customers in 2026." },
    { "type": "header", "content": "Image (droite)" },
    { "type": "image_picker", "id": "image", "label": "Image (1254 × 1254 px)" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistique",
      "settings": [
        { "type": "text", "id": "k", "label": "Petit libellé", "default": "1st stat" },
        { "type": "text", "id": "v", "label": "Valeur", "default": "89%" },
        { "type": "range", "id": "bar", "label": "Remplissage barre (%)", "min": 0, "max": 100, "step": 1, "default": 89 },
        { "type": "textarea", "id": "text", "label": "Texte", "default": "See a visibly slimmer silhouette within the first month." }
      ]
    }
  ],
  "default": {
    "blocks": [
        { "type": "stat", "settings": { "k": "1st stat", "v": "89%", "bar": 89, "text": "See a visibly slimmer silhouette within the first month." } },
        { "type": "stat", "settings": { "k": "2nd stat", "v": "94%", "bar": 94, "text": "Say they stand taller and feel more confident since wearing Sculpted™ daily." } },
        { "type": "stat", "settings": { "k": "3rd stat", "v": "96%", "bar": 96, "text": "Would recommend it to a friend to reach their silhouette and confidence goals." } }
    ]
  }
}
{% endschema %}

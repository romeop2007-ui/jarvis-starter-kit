{%- comment -%}
  Sculpted — "How does it work". Une seule image 1254×1254 (tout le visuel inclus dans l'image).
{%- endcomment -%}
<section class="how tint center">
  <div class="wrap">
    <div class="frame size-single{% if section.settings.image != blank %} has-img{% endif %}">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 1254 }}" alt="{{ section.settings.image_alt | escape }}" width="1254" height="1254" loading="lazy">
      {%- else -%}
        <span>1254 × 1254</span>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sculpted — How it works",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image (1254 × 1254 px)" },
    { "type": "text", "id": "image_alt", "label": "Texte alternatif (invisible, SEO)", "default": "How Sculpted works" }
  ]
}
{% endschema %}

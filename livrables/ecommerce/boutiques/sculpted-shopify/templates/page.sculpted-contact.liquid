{% layout 'sculpted' %}
{%- comment -%}
  ===========================================================================
  Sculpted — Template de page Contact (rendu 1:1 de la maquette Claude Design)
  ---------------------------------------------------------------------------
  Reproduction EXACTE de "Sculpted Contact.html" : ticker, header/nav, intro
  "Questions?", formulaire, badges de confiance, footer noir. Le CSS et le
  markup sont identiques à la maquette. Seules différences fonctionnelles :
    - le formulaire utilise le formulaire contact NATIF Shopify
      ({% form 'contact' %}) → les messages arrivent sur l'email de la boutique
    - les liens de nav pointent vers des URL Shopify (à ajuster quand les
      autres pages existeront)

  Déploiement : ce template utilise le layout isolé 'sculpted' (1re ligne),
  donc il ne dépend PAS du header/footer de ton thème.
  ===========================================================================
{%- endcomment -%}

<style>
/* ---------- 1. TOKENS ----------------------- */
:root{
  --ink:#101114;
  --paper:#ffffff;
  --soft:#f4f5f7;
  --muted:#73777e;
  --line:#e6e8eb;
  --accent:#1496d6;
  --accent-deep:#0c79b3;
  --ok:#1f9d57;
  --warn:#d2473c;
  --maxw:1180px;
  --gutter:24px;
  --r:14px;
  --t-h1:clamp(38px, 5.6vw, 76px);
  --t-body:17px;
  --t-eyebrow:13px;
}
/* ---------- 2. RESET / BASE ----------------- */
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'Archivo',system-ui,sans-serif;
  color:var(--ink);background:var(--paper);
  font-size:var(--t-body);line-height:1.55;
  -webkit-font-smoothing:antialiased;
}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer;border:none;background:none}
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 var(--gutter)}
.display{font-weight:900;line-height:1.02;letter-spacing:-.01em}
.accent{color:var(--accent)}
.icon{width:21px;height:21px;stroke:currentColor;fill:none;stroke-width:1.7}
/* ---------- 3. BUTTONS ---------------------- */
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:10px;
  font-weight:700;font-size:14px;letter-spacing:.08em;text-transform:uppercase;
  padding:18px 40px;border-radius:999px;transition:transform .15s ease, background .15s ease;
}
.btn:active{transform:translateY(1px)}
.btn-primary{background:var(--ink);color:#fff}
.btn-primary:hover{background:#000}
/* ---------- 4. ANNOUNCEMENT TICKER ---------- */
.ticker{background:var(--ink);color:#fff;overflow:hidden;white-space:nowrap}
.ticker-track{display:inline-flex;padding:10px 0;animation:scroll 28s linear infinite}
.ticker-track span{
  font-size:12px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;
  padding:0 36px;position:relative;
}
.ticker-track span::after{content:"•";position:absolute;right:-4px;opacity:.45}
@keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
/* ---------- 5. HEADER ----------------------- */
header{
  position:sticky;top:0;z-index:50;
  background:rgba(255,255,255,.92);backdrop-filter:blur(10px);
  border-bottom:1px solid var(--line);
}
.nav{display:flex;align-items:center;justify-content:space-between;height:74px}
.logo{font-weight:900;font-size:22px;letter-spacing:.04em;text-transform:uppercase}
.logo b{color:var(--accent)}
.nav-links{display:flex;gap:34px}
.nav-links a{font-weight:600;font-size:15px;position:relative}
.nav-links a:hover,.nav-links a.active{color:var(--accent)}
.nav-utils{display:flex;align-items:center;gap:22px}
.nav-utils .cur{font-weight:600;font-size:14px;display:flex;align-items:center;gap:6px}
/* ---------- 6. CONTACT SECTION -------------- */
.contact{padding:96px 0 110px}
.contact-grid{display:grid;grid-template-columns:1fr 1.15fr;gap:72px;align-items:start}
.contact-intro h1{font-size:var(--t-h1);margin-bottom:28px}
.contact-intro p{color:var(--muted);font-size:18px;max-width:34ch;margin-bottom:30px}
.contact-intro a.mail{font-weight:700;color:var(--ink);text-decoration:underline;text-underline-offset:4px}
.contact-meta{margin-top:40px;display:flex;flex-direction:column;gap:20px}
.contact-meta .row{display:flex;align-items:center;gap:14px}
.contact-meta .row .ic{width:22px;height:22px;stroke:var(--accent);fill:none;stroke-width:1.7;flex:none}
.contact-meta .row b{display:block;font-size:15px}
.contact-meta .row span{font-size:14px;color:var(--muted)}
/* form card */
.form-card{background:var(--soft);border-radius:var(--r);padding:40px}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px}
.field label{display:block;font-size:12px;font-weight:700;letter-spacing:.08em;
  text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.field input,.field textarea{
  width:100%;background:#fff;border:1px solid var(--line);border-radius:10px;
  padding:15px 16px;font-family:inherit;font-size:15px;color:var(--ink);outline:none;
  transition:border-color .15s, box-shadow .15s;
}
.field input:focus,.field textarea:focus{
  border-color:var(--accent);box-shadow:0 0 0 3px rgba(20,150,214,.12);
}
.field textarea{resize:vertical;min-height:150px}
.form-msg{margin-bottom:22px}
.sent-note{display:none;color:var(--ok);font-weight:700;font-size:14px;margin-top:16px}
.sent-note.show{display:block}
.error-note{color:var(--warn);font-weight:700;font-size:14px;margin-bottom:16px}
/* ---------- 7. TRUST BADGES ----------------- */
.trust-sec{padding:0 0 100px}
.tb-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:30px}
.tb{display:flex;flex-direction:column;align-items:center;gap:16px;text-align:center}
.tb .circ{width:74px;height:74px;border-radius:50%;background:#dbe7ee;
  display:flex;align-items:center;justify-content:center}
.tb:first-child .circ{background:var(--ink)}
.tb:first-child .circ svg{stroke:#fff}
.tb .circ svg{width:30px;height:30px;stroke:#4a5560;fill:none;stroke-width:1.6}
.tb p{font-weight:700;font-size:15px;max-width:16ch}
/* ---------- 8. FOOTER ----------------------- */
footer{background:var(--ink);color:#fff;padding:80px 0 40px}
.foot-top{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:48px;margin-bottom:64px}
.foot-news h3{font-size:30px;font-weight:700;line-height:1.15;margin-bottom:24px;max-width:14ch}
.news-input{display:flex;border:1px solid #34373d;border-radius:10px;overflow:hidden;max-width:420px}
.news-input input{flex:1;background:transparent;border:none;color:#fff;padding:16px 18px;font-family:inherit;font-size:15px;outline:none}
.news-input input::placeholder{color:#7c8088}
.news-input button{padding:0 20px;color:#fff;font-size:18px}
.foot-col h4{font-size:13px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:#8b9099;margin-bottom:20px}
.foot-col a{display:block;color:#d4d6da;font-size:15px;padding:7px 0}
.foot-col a:hover{color:#fff}
.foot-bot{display:flex;justify-content:space-between;align-items:center;
  border-top:1px solid #2a2d33;padding-top:30px;flex-wrap:wrap;gap:20px}
.foot-bot .cur{display:flex;align-items:center;gap:8px;font-weight:600;font-size:14px}
.foot-bot .cp{font-size:13px;color:#8b9099}
.foot-pay{display:flex;gap:8px;flex-wrap:wrap}
.foot-pay span{font-size:10px;font-weight:700;color:#9ba0a7;border:1px solid #34373d;border-radius:5px;padding:5px 8px}
/* ---------- 9. RESPONSIVE ------------------- */
@media (max-width:980px){
  .nav-links{display:none}
  .contact-grid{grid-template-columns:1fr;gap:44px}
  .foot-top{grid-template-columns:1fr;gap:36px}
  .tb-grid{grid-template-columns:1fr 1fr;gap:40px}
}
@media (max-width:560px){
  .contact{padding:60px 0 70px}
  .form-grid{grid-template-columns:1fr}
  .form-card{padding:26px}
}
</style>

<!-- ============ ANNOUNCEMENT TICKER ============ -->
<div class="ticker">
  <div class="ticker-track">
    <span>In stock — selling out fast</span>
    <span>Limited-time sale</span>
    <span>Free shipping until midnight tonight</span>
    <span>In stock — selling out fast</span>
    <span>Limited-time sale</span>
    <span>Free shipping until midnight tonight</span>
  </div>
</div>

<!-- ============ HEADER ============ -->
{%- comment -%} Liens de nav : à pointer vers les vraies pages Shopify quand elles existeront. {%- endcomment -%}
<header>
  <div class="wrap nav">
    <a href="{{ routes.root_url }}" class="logo">De<b>fyne</b></a>
    <nav class="nav-links">
      <a href="{{ routes.root_url }}">Home</a>
      <a href="{{ routes.root_url }}#product">Sculpted</a>
      <a href="{{ request.path }}" class="active">Contact</a>
      <a href="/pages/track-order">Track my order</a>
    </nav>
    <div class="nav-utils">
      <span class="cur">USD&nbsp;$ <svg class="icon" viewBox="0 0 24 24" style="width:14px;height:14px"><path d="M6 9l6 6 6-6"/></svg></span>
      <svg class="icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      <svg class="icon" viewBox="0 0 24 24"><path d="M6 6h15l-1.5 9h-12z"/><circle cx="9" cy="20" r="1.4"/><circle cx="18" cy="20" r="1.4"/><path d="M6 6L5 3H2"/></svg>
    </div>
  </div>
</header>

<!-- ============ CONTACT ============ -->
<section class="contact">
  <div class="wrap contact-grid">

    <!-- intro / details -->
    <div class="contact-intro">
      <h1 class="display">Questions?</h1>
      <p>Get in touch below, or email us anytime — we reply within 24 hours.</p>
      <a href="mailto:hello@sculpted.com" class="mail">hello@sculpted.com</a>

      <div class="contact-meta">
        <div class="row">
          <svg class="ic" viewBox="0 0 24 24"><path d="M4 5h16v14H4z"/><path d="M4 6l8 6 8-6"/></svg>
          <div><b>Email</b><span>hello@sculpted.com</span></div>
        </div>
        <div class="row">
          <svg class="ic" viewBox="0 0 24 24"><path d="M4 13a8 8 0 0116 0M4 13v3a2 2 0 002 2M20 13v3a2 2 0 01-2 2h-3"/></svg>
          <div><b>Customer service</b><span>Available 24/7</span></div>
        </div>
        <div class="row">
          <svg class="ic" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
          <div><b>Response time</b><span>Within 24 hours</span></div>
        </div>
      </div>
    </div>

    <!-- form (formulaire contact natif Shopify) -->
    <div class="form-card">
      {%- form 'contact', id: 'contactForm' -%}
        {%- if form.posted_successfully? -%}
          <p class="sent-note show">Thanks — your message is on its way. We'll be in touch within 24 hours.</p>
        {%- elsif form.errors -%}
          <p class="error-note">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <div class="form-grid">
          <div class="field">
            <label for="name">Name</label>
            <input type="text" id="name" name="contact[name]" placeholder="Your name" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" required />
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input type="email" id="email" name="contact[email]" placeholder="you@email.com" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required />
          </div>
        </div>
        <div class="field form-msg">
          <label for="message">Message</label>
          <textarea id="message" name="contact[body]" placeholder="How can we help?" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>
        <button type="submit" class="btn btn-primary">Send message</button>
      {%- endform -%}
    </div>

  </div>
</section>

<!-- ============ TRUST BADGES ============ -->
<section class="trust-sec">
  <div class="wrap">
    <div class="tb-grid">
      <div class="tb"><div class="circ"><svg viewBox="0 0 24 24"><path d="M3 8l9-5 9 5-9 5z"/><path d="M3 8v8l9 5 9-5V8"/><path d="M12 13v8"/></svg></div><p>Free shipping</p></div>
      <div class="tb"><div class="circ"><svg viewBox="0 0 24 24"><path d="M4 13a8 8 0 0116 0M4 13v3a2 2 0 002 2M20 13v3a2 2 0 01-2 2h-3"/></svg></div><p>24/7 customer service</p></div>
      <div class="tb"><div class="circ"><svg viewBox="0 0 24 24"><path d="M21 12a9 9 0 11-3-6.7M21 4v5h-5"/></svg></div><p>30-day money-back guarantee</p></div>
      <div class="tb"><div class="circ"><svg viewBox="0 0 24 24"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 018 0v3"/></svg></div><p>Secure payments</p></div>
    </div>
  </div>
</section>

<!-- ============ FOOTER ============ -->
<footer>
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-news">
        <h3>Sign up for our newsletter</h3>
        <form class="news-input" onsubmit="return false">
          <input type="email" placeholder="E-mail" />
          <button type="submit">›</button>
        </form>
      </div>
      <div class="foot-col">
        <h4>Menu</h4>
        <a href="{{ routes.root_url }}">Home</a>
        <a href="{{ routes.root_url }}#product">Sculpted</a>
        <a href="{{ request.path }}">Contact</a>
        <a href="/pages/track-order">Track my order</a>
      </div>
      <div class="foot-col">
        <h4>Information</h4>
        <a href="{{ request.path }}">Contact</a>
        <a href="#">Privacy policy</a>
        <a href="#">Refund policy</a>
        <a href="#">Shipping policy</a>
        <a href="#">Terms of sale</a>
        <a href="#">Terms of use</a>
        <a href="#">Legal notice</a>
      </div>
    </div>
    <div class="foot-bot">
      <span class="cur">🇺🇸 United States (USD $) <svg class="icon" viewBox="0 0 24 24" style="width:14px;height:14px;stroke:#fff"><path d="M6 9l6 6 6-6"/></svg></span>
      <span class="cp">© 2026, Sculpted</span>
      <div class="foot-pay"><span>AMEX</span><span>Apple Pay</span><span>Diners</span><span>Discover</span><span>G Pay</span><span>JCB</span><span>Mastercard</span><span>VISA</span></div>
    </div>
  </div>
</footer>

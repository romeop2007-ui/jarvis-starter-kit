{% comment %} Section avis clients Zooryn {% endcomment %}

{%- style -%}
  .avis-clients {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .avis-clients__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .avis-clients__header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .avis-clients__caption {
    display: block;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 0.5rem;
  }
  .avis-clients__heading {
    font-size: 2rem;
    margin: 0;
  }
  .avis-clients__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 900px) {
    .avis-clients__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .avis-clients__grid { grid-template-columns: 1fr; }
  }
  .avis-card {
    background: var(--color-background);
    border: 2px solid rgba(21,66,48,0.28);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    box-shadow: 0 2px 8px rgba(21,66,48,0.07);
  }
  .avis-card__stars {
    color: #f5a623;
    font-size: 1.1rem;
    letter-spacing: 2px;
  }
  .avis-card__text {
    font-size: 0.95rem;
    line-height: 1.6;
    flex: 1;
  }
  .avis-card__footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    border-top: 1.5px solid rgba(21,66,48,0.1);
    padding-top: 0.85rem;
    margin-top: 0.25rem;
    gap: 0.5rem;
  }
  .avis-card__name {
    font-weight: 700;
    font-size: 0.88rem;
    color: var(--color-foreground);
  }
  .avis-card__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.3rem;
  }
  .avis-card__verified {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: rgba(21,66,48,0.08);
    color: #154230;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.2rem 0.55rem 0.2rem 0.35rem;
    border-radius: 100px;
    border: 1px solid rgba(21,66,48,0.18);
    white-space: nowrap;
  }
  .avis-card__verified svg {
    flex-shrink: 0;
  }
  .avis-card__date {
    font-size: 0.72rem;
    opacity: 0.5;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
{%- endstyle -%}

<div class="avis-clients color-{{ section.settings.color_scheme }} gradient">
  <div class="avis-clients__inner">
    <div class="avis-clients__header">
      <span class="avis-clients__caption">{{ section.settings.caption }}</span>
      <h2 class="avis-clients__heading">{{ section.settings.heading }}</h2>
    </div>
    <div class="avis-clients__grid">
      {%- for block in section.blocks -%}
        <div class="avis-card" {{ block.shopify_attributes }}>
          <div class="avis-card__stars">★★★★★</div>
          <p class="avis-card__text">{{ block.settings.texte }}</p>
          <div class="avis-card__footer">
            <span class="avis-card__name">{{ block.settings.nom }}</span>
            <div class="avis-card__meta">
              <span class="avis-card__verified">
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="5.5" cy="5.5" r="5.5" fill="#154230"/>
                  <path d="M3 5.5L4.8 7.3L8 4" stroke="white" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Achat vérifié
              </span>
              <span class="avis-card__date">{{ block.settings.date }}</span>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Avis clients",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "caption",
      "label": "Sous-titre",
      "default": "Ce qu'ils disent"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Ils nous ont fait confiance"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "scheme-1", "label": "Schéma 1" },
        { "value": "scheme-2", "label": "Schéma 2" },
        { "value": "scheme-3", "label": "Schéma 3" }
      ],
      "default": "scheme-1",
      "label": "Couleur de fond"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espacement haut",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espacement bas",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "avis",
      "name": "Avis",
      "settings": [
        {
          "type": "textarea",
          "id": "texte",
          "label": "Texte de l'avis"
        },
        {
          "type": "text",
          "id": "nom",
          "label": "Prénom + initiale"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avis clients"
    }
  ]
}
{% endschema %}

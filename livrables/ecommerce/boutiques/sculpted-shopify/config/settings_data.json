      "sculpted-faq-shin": {
        "type": "sculpted-faq-shin",
        "blocks": {
          "sculpted-faq-shin-0": {
            "type": "item",
            "settings": {
              "question": "Who are Zooryn Shin Protectors for?",
              "answer": "Any footballer — from grassroots and Sunday League to semi-pro — who's sick of taping their socks and chasing slipping shin guards. They're also a favourite with parents buying for younger players."
            }
          },
          "sculpted-faq-shin-1": {
            "type": "item",
            "settings": {
              "question": "Do the shin guards really stay in place?",
              "answer": "Yes. The integrated lock-in sleeve grips the guard and the compression knit holds your leg, so the guard stays put for the full 90 — no tape needed."
            }
          },
          "sculpted-faq-shin-2": {
            "type": "item",
            "settings": {
              "question": "Are they match-legal?",
              "answer": "They're designed to meet standard shin guard regulations. Leagues vary, so always check your competition's specific rules before play."
            }
          },
          "sculpted-faq-shin-3": {
            "type": "item",
            "settings": {
              "question": "Is the grip on the sole allowed?",
              "answer": "Yes. The anti-slip pads sit inside your boot and simply stop your foot sliding — the same idea as the grip socks worn across professional football."
            }
          },
          "sculpted-faq-shin-4": {
            "type": "item",
            "settings": {
              "question": "How do I choose my size?",
              "answer": "Pick by shoe size using the size guide. We offer free size exchanges within 30 days if you're between sizes."
            }
          },
          "sculpted-faq-shin-5": {
            "type": "item",
            "settings": {
              "question": "Can I machine wash them?",
              "answer": "Yes — wash at 30°C on a gentle cycle and hang to dry. Avoid bleach, tumble drying and ironing the grip pads."
            }
          },
          "sculpted-faq-shin-6": {
            "type": "item",
            "settings": {
              "question": "Are they comfortable or too tight?",
              "answer": "Firm but breathable. The compression is what keeps everything locked in, but it shouldn't cut in — pick the right size and they feel like a second skin."
            }
          },
          "sculpted-faq-shin-7": {
            "type": "item",
            "settings": {
              "question": "Will they fit a child?",
              "answer": "Yes, we stock a Kids UK 10-2 size. Measure by shoe size and size up if your child is between sizes or still growing."
            }
          }
        },
